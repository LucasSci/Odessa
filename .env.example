# Gemini is the primary AI provider for persona decisions.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OpenAI is used as fallback for persona AI when Gemini is unavailable.
# It is also required for premium TTS voices: alloy, echo, fable, onyx, nova, shimmer.
OPENAI_API_KEY=""
OPENAI_TEXT_MODEL="gpt-4o-mini"
OPENAI_TTS_MODEL="gpt-4o-mini-tts"
OPENAI_IMAGE_MODEL="gpt-image-1"
OPENAI_IMAGE_SIZE=""
OPENAI_IMAGE_QUALITY="auto"
TTS_DEFAULT_PROVIDER="edge"
KOKORO_ENABLED="true"
KOKORO_DEFAULT_LANG="p"
KOKORO_DEFAULT_VOICE="pf_dora"
KOKORO_DEFAULT_SPEED="1.0"
# Optional when espeak-ng is installed but not exposed in PATH.
ESPEAK_NG_PATH="C:\\Program Files\\eSpeak NG\\espeak-ng.exe"

# Frontend API target. The default backend dev server uses port 8000.
VITE_API_BASE_URL="http://localhost:8000"

# Optional hosted app URL.
APP_URL="http://localhost:3000"

# Odessa Cloud / local agent bridge.
ODESSA_CLOUD_URL="https://odessa-gules.vercel.app"
ODESSA_PUBLIC_URL="https://odessa-gules.vercel.app"
ODESSA_AGENT_ID="live-machine"
ODESSA_AGENT_TOKEN="generate-a-shared-secret-and-configure-the-same-value-in-vercel"
ODESSA_AGENT_HEARTBEAT_SECONDS="10"
ODESSA_AGENT_COMMAND_SECONDS="2"
ODESSA_AGENT_HOST="127.0.0.1"
ODESSA_AGENT_PORT="8766"

# Odessa Cloud persistence on Vercel.
# DATABASE_URL comes from Neon Postgres in Vercel Marketplace.
# BLOB_READ_WRITE_TOKEN comes from Vercel Blob.
DATABASE_URL=""
BLOB_READ_WRITE_TOKEN=""

# Optional n8n bridge. Keep these values only on the backend/local .env,
# never in VITE_* variables or frontend code.
N8N_BASE_URL="http://localhost:5678"
N8N_LOCAL_REPO=""
N8N_WEBHOOK_SECRET="change-me-local-secret"
N8N_AUDIT_WEBHOOK_URL=""
N8N_ACTION_WEBHOOK_URL=""
N8N_EVENT_INGEST_WEBHOOK_URL=""
N8N_PROJECT_CREATION_WEBHOOK_URL=""
N8N_NIGHT_SHIFT_WEBHOOK_URL=""
N8N_CONTINUOUS_ORGANIZER_WEBHOOK_URL=""
N8N_VISUAL_ASSET_WEBHOOK_URL=""
# Generic action webhooks are configured from the Odessa Settings page and
# persisted in server/runtime/webhook_actions.json. Use n8n as a normal
# webhook target instead of depending on hidden /n8n routes.
# OBS is required for assisted live OCR.
# Enable OBS WebSocket in OBS: Tools -> WebSocket Server Settings.
# Default host/port: localhost:4455. Store the OBS password only in local env files.
# Create a persistent Browser Source named "Odessa Chat OCR" with the live chat.
# Avoid shutting down or refreshing that source when it is hidden.
# Optional for the n8n process itself: incoming Slack webhook used by Project Creation Pipeline.
N8N_SLACK_WEBHOOK_URL=""
ODESSA_DB_PATH="server/runtime/odessa.db"
ODESSA_PROJECT_OUTPUT_DIR="server/runtime/project-plans"
ODESSA_VISUAL_OUTPUT_DIR="server/runtime/visual-assets"
ODESSA_MAX_VISUAL_IMAGES_PER_RUN="3"
ODESSA_VISUAL_SCHEDULE_GENERATE_IMAGES="false"
ODESSA_VISUAL_IMAGE_PROVIDER="auto"
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"
GEMINI_IMAGE_ASPECT_RATIO="9:16"
GEMINI_IMAGE_SIZE=""

# Automation & Service Config
AI_PROVIDER=gemini
ENABLE_LOCAL_FALLBACK=true

ENABLE_TTS=false
TTS_SIMULATION_MODE=true

OBS_ENABLED=true
OBS_WEBSOCKET_URL=ws://localhost:4455
OBS_WEBSOCKET_PASSWORD=
OBS_OCR_SOURCE_NAME="Odessa Chat OCR"
OBS_SCENE_WHITELIST=Gameplay Focus,Cena Just Chatting,Tela de reacts

SIMULATION_MODE=true

MAX_EVENTS_PER_TICK=10
GIFT_DEBOUNCE_MS=1500
GIFT_BATCH_WINDOW_MS=2500
EVENT_PROCESSING_TIMEOUT_MS=10000

TOPIC_SUGGEST_COOLDOWN_MS=60000
VIDEO_TRIGGER_COOLDOWN_MS=15000

DEFAULT_RECEIVER=Odessa

# Optional backend runtime paths.
# CAPTURE_LOG_FILE="server/runtime/captura_chat.txt"
# CAPTURE_REGION_FILE="server/runtime/regions.json"
