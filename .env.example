# Gemini powers AI persona responses through the local backend.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OpenAI is only required for premium TTS voices: alloy, echo, fable, onyx, nova, shimmer.
# Leave empty and select an Edge/Azure voice in the UI if you do not want premium TTS.
OPENAI_API_KEY=""

# Frontend API target. The default backend dev server uses port 8000.
VITE_API_BASE_URL="http://localhost:8000"

# Optional hosted app URL.
APP_URL="http://localhost:3000"

# Optional backend runtime paths.
# CAPTURE_LOG_FILE="server/runtime/captura_chat.txt"
# CAPTURE_REGION_FILE="server/runtime/regions.json"
