# ── Autenticação ──────────────────────────────────────────────────────────────
# Use HASH (bcrypt) em produção para evitar problemas com caracteres especiais.
# Em dev, ODESSA_ADMIN_PASSWORD aceita a senha em texto puro.
ODESSA_ADMIN_PASSWORD=troque-esta-senha
# ODESSA_ADMIN_PASSWORD_HASH=   # bcrypt hash (produção)
ODESSA_SESSION_SECRET=gere-um-segredo-longo-e-aleatorio

# ── URLs ───────────────────────────────────────────────────────────────────────
# Em dev, aponte para localhost.
APP_URL=http://localhost:3000
ODESSA_PUBLIC_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8000

# ── Cookies ───────────────────────────────────────────────────────────────────
ODESSA_COOKIE_SECURE=false        # true em produção (HTTPS)
ODESSA_COOKIE_SAMESITE=lax        # Lax em produção
ODESSA_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── OBS ───────────────────────────────────────────────────────────────────────
# Habilite o OBS WebSocket em: Tools → WebSocket Server Settings (porta 4455).
# A Browser Source "Odessa Chat OCR" deve permanecer ativa (não feche quando ocultar).
OBS_ENABLED=true
OBS_WEBSOCKET_URL=ws://localhost:4455
OBS_WEBSOCKET_PASSWORD=
OBS_OCR_SOURCE_NAME="Odessa Chat OCR"
OBS_SCENE_WHITELIST=Gameplay Focus,Cena Just Chatting,Tela de reacts

# ── IA ────────────────────────────────────────────────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=MY_GEMINI_API_KEY

# OpenAI: fallback de IA e vozes TTS premium (alloy, echo, fable, onyx, nova, shimmer)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=auto

# ── TTS ───────────────────────────────────────────────────────────────────────
ENABLE_TTS=false
TTS_DEFAULT_PROVIDER=edge
TTS_SIMULATION_MODE=true

# Kokoro TTS (local)
KOKORO_ENABLED=true
KOKORO_DEFAULT_LANG=p
KOKORO_DEFAULT_VOICE=pf_dora
KOKORO_DEFAULT_SPEED=1.0

# Opcional — necessário somente se espeak-ng não estiver no PATH
# ESPEAK_NG_PATH=C:\Program Files\eSpeak NG\espeak-ng.exe

# ── Automação ─────────────────────────────────────────────────────────────────
ENABLE_LOCAL_FALLBACK=true
SIMULATION_MODE=true

MAX_EVENTS_PER_TICK=10
GIFT_DEBOUNCE_MS=1500
GIFT_BATCH_WINDOW_MS=2500
EVENT_PROCESSING_TIMEOUT_MS=10000

TOPIC_SUGGEST_COOLDOWN_MS=60000
VIDEO_TRIGGER_COOLDOWN_MS=15000

DEFAULT_RECEIVER=Odessa

# ── Banco de dados / runtime ───────────────────────────────────────────────────
ODESSA_DB_PATH=server/runtime/odessa.db
ODESSA_PROJECT_OUTPUT_DIR=server/runtime/project-plans
ODESSA_VISUAL_OUTPUT_DIR=server/runtime/visual-assets

# ── Geração de imagens ────────────────────────────────────────────────────────
ODESSA_MAX_VISUAL_IMAGES_PER_RUN=3
ODESSA_VISUAL_SCHEDULE_GENERATE_IMAGES=false
ODESSA_VISUAL_IMAGE_PROVIDER=auto
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_IMAGE_ASPECT_RATIO=9:16

# ── n8n (opcional) ────────────────────────────────────────────────────────────
# Configure webhooks na página de Configurações do painel Odessa.
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=change-me-local-secret
N8N_ACTION_WEBHOOK_URL=
N8N_EVENT_INGEST_WEBHOOK_URL=
