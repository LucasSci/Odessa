# Gemini is the primary AI provider for persona decisions.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OpenAI is used as fallback for persona AI when Gemini is unavailable.
# It is also required for premium TTS voices: alloy, echo, fable, onyx, nova, shimmer.
OPENAI_API_KEY=""
OPENAI_TEXT_MODEL="gpt-4o-mini"
OPENAI_TTS_MODEL="gpt-4o-mini-tts"
OPENAI_IMAGE_MODEL="gpt-image-1"
OPENAI_IMAGE_SIZE=""
OPENAI_IMAGE_QUALITY="auto"
TTS_DEFAULT_PROVIDER="edge"
KOKORO_ENABLED="true"
KOKORO_DEFAULT_LANG="p"
KOKORO_DEFAULT_VOICE="pf_dora"
KOKORO_DEFAULT_SPEED="1.0"
# Optional when espeak-ng is installed but not exposed in PATH.
ESPEAK_NG_PATH="C:\\Program Files\\eSpeak NG\\espeak-ng.exe"

# Frontend API target. The default backend dev server uses port 8000.
VITE_API_BASE_URL="http://localhost:8000"

# Optional hosted app URL.
APP_URL="http://localhost:3000"

# Optional n8n bridge. Keep these values only on the backend/local .env,
# never in VITE_* variables or frontend code.
N8N_BASE_URL="http://localhost:5678"
N8N_LOCAL_REPO=""
N8N_WEBHOOK_SECRET="change-me-local-secret"
N8N_AUDIT_WEBHOOK_URL=""
N8N_ACTION_WEBHOOK_URL=""
N8N_EVENT_INGEST_WEBHOOK_URL=""
N8N_PROJECT_CREATION_WEBHOOK_URL=""
N8N_NIGHT_SHIFT_WEBHOOK_URL=""
N8N_CONTINUOUS_ORGANIZER_WEBHOOK_URL=""
N8N_VISUAL_ASSET_WEBHOOK_URL=""
# OBS real runs through the n8n action workflow.
# Enable OBS WebSocket in OBS: Tools -> WebSocket Server Settings.
# Default host/port: localhost:4455. Store the OBS password in n8n credentials,
# never in frontend variables or committed files.
# Install the n8n community node: @mashgizmo/n8n-nodes-obs-websocket.
# Optional for the n8n process itself: incoming Slack webhook used by Project Creation Pipeline.
N8N_SLACK_WEBHOOK_URL=""
ODESSA_DB_PATH="server/runtime/odessa.db"
ODESSA_PROJECT_OUTPUT_DIR="server/runtime/project-plans"
ODESSA_VISUAL_OUTPUT_DIR="server/runtime/visual-assets"
ODESSA_MAX_VISUAL_IMAGES_PER_RUN="3"
ODESSA_VISUAL_SCHEDULE_GENERATE_IMAGES="false"
ODESSA_VISUAL_IMAGE_PROVIDER="auto"
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"
GEMINI_IMAGE_ASPECT_RATIO="9:16"
GEMINI_IMAGE_SIZE=""

# Optional backend runtime paths.
# CAPTURE_LOG_FILE="server/runtime/captura_chat.txt"
# CAPTURE_REGION_FILE="server/runtime/regions.json"
