def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat()


def local_time_label() -> str:
    return datetime.now().strftime("%H:%M:%S")


def read_json_list(path: Path) -> list[dict[str, Any]]:
    if not path.exists():
        return []
    try:
        parsed = json.loads(path.read_text(encoding="utf-8"))
        return parsed if isinstance(parsed, list) else []
    except Exception as exc:
        logger.warning("Could not read JSON list %s: %s", path, exc)
        return []


def write_json_list(path: Path, items: list[dict[str, Any]]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(items, ensure_ascii=False, indent=2), encoding="utf-8")


def verify_n8n_secret(request: Request) -> None:
    if not N8N_WEBHOOK_SECRET:
        return
    provided = request.headers.get("X-Odessa-Secret", "")
    if provided != N8N_WEBHOOK_SECRET:
        raise HTTPException(status_code=401, detail="Invalid X-Odessa-Secret")


def append_n8n_audit(
    kind: str,
    payload: dict[str, Any],
    outcome: Optional[dict[str, Any]] = None,
) -> None:
    try:
        items = read_json_list(N8N_AUDIT_FILE)
        items.append(
            {
                "id": f"n8n-audit-{int(time.time() * 1000)}",
                "kind": kind,
                "payload": payload,
                "outcome": outcome or {},
                "createdAt": utc_now(),
            }
        )
        write_json_list(N8N_AUDIT_FILE, items[-200:])
    except Exception as exc:
        logger.warning("Could not append n8n audit: %s", exc)


def normalize_n8n_event(raw: Any, index: int) -> dict[str, Any]:
    if not isinstance(raw, dict):
        raw = {"text": str(raw)}

    metadata = raw.get("metadata") if isinstance(raw.get("metadata"), dict) else {}
    original_source = str(raw.get("source") or "n8n").strip() or "n8n"
    source = original_source if original_source in ALLOWED_EVENT_SOURCES else "n8n"
    if original_source != source:
        metadata = {**metadata, "originalSource": original_source}

    kind = str(raw.get("kind") or raw.get("type") or "chat").strip().lower()
    if kind not in ALLOWED_EVENT_KINDS:
        kind = "system"

    text = str(raw.get("text") or raw.get("message") or "").strip()
    if not text:
        text = json.dumps(raw, ensure_ascii=False)

    return {
        "id": str(raw.get("id") or f"n8n-event-{int(time.time() * 1000)}-{index}"),
        "source": source,
        "zoneName": str(raw.get("zoneName") or raw.get("zone_name") or "n8n").strip()
        or "n8n",
        "text": text,
        "kind": kind,
        "createdAt": str(raw.get("createdAt") or raw.get("created_at") or utc_now()),
        "time": str(raw.get("time") or local_time_label()),
        "metadata": {**metadata, "n8nReceivedAt": utc_now()},
    }


def post_json_to_n8n(url: str, payload: dict[str, Any]) -> dict[str, Any]:
    headers = {"Content-Type": "application/json"}
    if N8N_WEBHOOK_SECRET:
        headers["X-Odessa-Secret"] = N8N_WEBHOOK_SECRET

    body = json.dumps(payload, ensure_ascii=False).encode("utf-8")
    request = url_request.Request(url, data=body, headers=headers, method="POST")
    try:
        with url_request.urlopen(request, timeout=N8N_HTTP_TIMEOUT) as response:
            response_body = response.read(16384).decode("utf-8", errors="replace")
            return {
                "status_code": response.status,
                "body": response_body,
            }
    except HTTPError as exc:
        response_body = exc.read(4096).decode("utf-8", errors="replace")
        raise HTTPException(
            status_code=502,
            detail=f"n8n webhook returned HTTP {exc.code}: {response_body[:240]}",
        ) from exc
    except (URLError, TimeoutError, OSError) as exc:
        raise HTTPException(status_code=502, detail=f"n8n unreachable: {exc}") from exc


def parse_json_body(value: Any) -> Any:
    if isinstance(value, (dict, list)):
        return value
    if not isinstance(value, str) or not value.strip():
        return None
    try:
        return json.loads(value)
    except json.JSONDecodeError:
        return None


def first_dict(*values: Any) -> dict[str, Any]:
    for value in values:
        if isinstance(value, dict):
            return value
    return {}


def extract_scene_list(payload: Any) -> tuple[list[str], Optional[str]]:
    data = first_dict(payload)
    if not data and isinstance(payload, list) and payload and isinstance(payload[0], dict):
        data = payload[0]

    nested = first_dict(
        data.get("payload"),
        data.get("data"),
        data.get("response"),
        data.get("body"),
    )
    scene_candidates = (
        data.get("scenes")
        or data.get("sceneNames")
        or nested.get("scenes")
        or nested.get("sceneNames")
        or []
    )
    scenes: list[str] = []
    if isinstance(scene_candidates, list):
        for scene in scene_candidates:
            if isinstance(scene, str):
                name = scene.strip()
            elif isinstance(scene, dict):
                name = str(scene.get("sceneName") or scene.get("name") or "").strip()
            else:
                name = ""
            if name and name not in scenes:
                scenes.append(name)

    current_scene = (
        data.get("currentScene")
        or data.get("currentProgramSceneName")
        or nested.get("currentScene")
        or nested.get("currentProgramSceneName")
    )
    return scenes, str(current_scene).strip() if current_scene else None


def model_payload(value: Any) -> dict[str, Any]:
    if hasattr(value, "model_dump"):
        return value.model_dump()
    if hasattr(value, "dict"):
        return value.dict()
    return dict(value)


def memory_db_connection() -> sqlite3.Connection:
    ODESSA_DB_PATH.parent.mkdir(parents=True, exist_ok=True)
    connection = sqlite3.connect(ODESSA_DB_PATH)
    connection.row_factory = sqlite3.Row
    connection.execute(
        """
        CREATE TABLE IF NOT EXISTS users (
            id TEXT PRIMARY KEY,
            username TEXT NOT NULL,
            first_seen TEXT NOT NULL,
            last_seen TEXT NOT NULL,
            total_messages INTEGER NOT NULL DEFAULT 0,
            total_gifts INTEGER NOT NULL DEFAULT 0,
            sentiment TEXT NOT NULL DEFAULT 'neutral'
        )
        """
    )
    connection.execute(
        """
        CREATE TABLE IF NOT EXISTS interaction_logs (
            id TEXT PRIMARY KEY,
            user_id TEXT,
            username TEXT,
            kind TEXT NOT NULL,
            source TEXT NOT NULL,
            text TEXT NOT NULL,
            metadata_json TEXT NOT NULL,
            sentiment TEXT NOT NULL DEFAULT 'neutral',
            created_at TEXT NOT NULL
        )
        """
    )
    connection.execute(
        "CREATE INDEX IF NOT EXISTS idx_interaction_user ON interaction_logs(user_id)"
    )
    connection.execute(
        "CREATE INDEX IF NOT EXISTS idx_interaction_created ON interaction_logs(created_at)"
    )
    connection.commit()
    return connection


def normalize_user_id(username: str) -> str:
    normalized = re.sub(r"[^0-9a-zA-Z_.-]+", "-", username.strip().lower()).strip("-")
    return normalized or f"user-{int(time.time() * 1000)}"


def extract_username_from_event(event: dict[str, Any]) -> Optional[str]:
    metadata = event.get("metadata") if isinstance(event.get("metadata"), dict) else {}
    for key in ("user", "username", "sender", "author"):
        value = metadata.get(key)
        if isinstance(value, str) and value.strip():
            return value.strip().lstrip("@")

    text = str(event.get("text") or "").strip()
    patterns = [
        r"^@?([A-Za-zÀ-ÿ0-9_.-]{2,32})\s*(?:[:\-]|disse|falou|comentou|enviou|mandou|deu|resgatou|pediu)\b",
        r"\bde\s+@?([A-Za-zÀ-ÿ0-9_.-]{2,32})\b",
    ]
    for pattern in patterns:
        match = re.search(pattern, text, flags=re.IGNORECASE)
        if match:
            return match.group(1).strip().lstrip("@")
    return None


def numeric_metadata_value(metadata: dict[str, Any], key: str, default: int = 0) -> int:
    value = metadata.get(key, default)
    try:
        return max(0, int(value))
    except (TypeError, ValueError):
        return default


def summarize_memory_users(users: list[dict[str, Any]]) -> str:
    if not users:
        return ""

    lines = []
    for user in users[:8]:
        recurring = "recorrente" if user.get("returning") else "novo na memoria"
        gifts = int(user.get("totalGifts") or 0)
        interactions = int(user.get("interactions") or 0)
        details = [f"{user.get('username')} e {recurring}"]
        if gifts:
            details.append(f"ja enviou {gifts} presente(s)")
        if interactions:
            details.append(f"tem {interactions} interacao(oes) registradas")
        lines.append("- " + "; ".join(details))
    return "Usuarios reconhecidos nesta rodada:\n" + "\n".join(lines)


def get_memory_stats() -> dict[str, Any]:
    try:
        with memory_db_connection() as connection:
            users = connection.execute("SELECT COUNT(*) AS count FROM users").fetchone()
            interactions = connection.execute(
                "SELECT COUNT(*) AS count FROM interaction_logs"
            ).fetchone()
            gifts = connection.execute(
                "SELECT COALESCE(SUM(total_gifts), 0) AS total FROM users"
            ).fetchone()
        return {
            "usersRecognized": int(users["count"] if users else 0),
            "interactions": int(interactions["count"] if interactions else 0),
            "gifts": int(gifts["total"] if gifts else 0),
            "dbPath": str(ODESSA_DB_PATH),
        }
    except Exception as exc:
        logger.warning("Could not read memory stats: %s", exc)
        return {
            "usersRecognized": 0,
            "interactions": 0,
            "gifts": 0,
            "dbPath": str(ODESSA_DB_PATH),
            "error": str(exc),
        }


def upsert_round_memory(events: list[dict[str, Any]]) -> dict[str, Any]:
    now = utc_now()
    users_seen: dict[str, dict[str, Any]] = {}
    with memory_db_connection() as connection:
        for index, event in enumerate(events):
            username = extract_username_from_event(event)
            if not username:
                continue

            metadata = event.get("metadata") if isinstance(event.get("metadata"), dict) else {}
            kind = str(event.get("kind") or "chat")
            source = str(event.get("source") or "manual")
            user_id = normalize_user_id(username)
            existing = connection.execute(
                "SELECT * FROM users WHERE id = ?",
                (user_id,),
            ).fetchone()
            quantity = numeric_metadata_value(metadata, "quantity", 1 if kind == "gift" else 0)
            message_delta = 1 if kind == "chat" else 0
            sentiment = str(metadata.get("sentiment") or "neutral")

            if existing:
                total_messages = int(existing["total_messages"]) + message_delta
                total_gifts = int(existing["total_gifts"]) + quantity
                connection.execute(
                    """
                    UPDATE users
                    SET username = ?, last_seen = ?, total_messages = ?,
                        total_gifts = ?, sentiment = ?
                    WHERE id = ?
                    """,
                    (username, now, total_messages, total_gifts, sentiment, user_id),
                )
                returning = True
                first_seen = str(existing["first_seen"])
            else:
                total_messages = message_delta
                total_gifts = quantity
                first_seen = now
                connection.execute(
                    """
                    INSERT INTO users (
                        id, username, first_seen, last_seen,
                        total_messages, total_gifts, sentiment
                    ) VALUES (?, ?, ?, ?, ?, ?, ?)
                    """,
                    (user_id, username, first_seen, now, total_messages, total_gifts, sentiment),
                )
                returning = False

            connection.execute(
                """
                INSERT INTO interaction_logs (
                    id, user_id, username, kind, source, text,
                    metadata_json, sentiment, created_at
                ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
                """,
                (
                    f"log-{int(time.time() * 1000)}-{index}-{user_id}",
                    user_id,
                    username,
                    kind,
                    source,
                    str(event.get("text") or ""),
                    json.dumps(metadata, ensure_ascii=False),
                    sentiment,
                    str(event.get("createdAt") or now),
                ),
            )

            users_seen[user_id] = {
                "id": user_id,
                "username": username,
                "returning": returning,
                "firstSeen": first_seen,
                "lastSeen": now,
                "totalMessages": total_messages,
                "totalGifts": total_gifts,
                "interactions": total_messages + total_gifts,
                "sentiment": sentiment,
            }
        connection.commit()

    users = list(users_seen.values())
    return {
        "usersRecognized": len(users),
        "context": summarize_memory_users(users),
        "users": users,
    }


def n8n_health() -> dict[str, Any]:
    configured = bool(
        N8N_BASE_URL
        or N8N_AUDIT_WEBHOOK_URL
        or N8N_ACTION_WEBHOOK_URL
        or N8N_EVENT_INGEST_WEBHOOK_URL
        or N8N_PROJECT_CREATION_WEBHOOK_URL
        or N8N_NIGHT_SHIFT_WEBHOOK_URL
        or N8N_VISUAL_ASSET_WEBHOOK_URL
    )
    status: dict[str, Any] = {
        "configured": configured,
        "base_url": N8N_BASE_URL or None,
        "base_url_configured": bool(N8N_BASE_URL),
        "audit_webhook_configured": bool(N8N_AUDIT_WEBHOOK_URL),
        "action_webhook_configured": bool(N8N_ACTION_WEBHOOK_URL),
        "event_ingest_webhook_configured": bool(N8N_EVENT_INGEST_WEBHOOK_URL),
        "project_creation_webhook_configured": bool(N8N_PROJECT_CREATION_WEBHOOK_URL),
        "night_shift_webhook_configured": bool(N8N_NIGHT_SHIFT_WEBHOOK_URL),
        "visual_asset_webhook_configured": bool(N8N_VISUAL_ASSET_WEBHOOK_URL),
        "secret_configured": bool(N8N_WEBHOOK_SECRET),
        "online": False,
        "error": None,
    }
    if not N8N_BASE_URL:
        return status

    try:
        health_url = N8N_BASE_URL.rstrip("/") + "/healthz"
        request = url_request.Request(health_url, method="GET")
        with url_request.urlopen(request, timeout=1.2) as response:
            status["online"] = 200 <= response.status < 500
            status["status_code"] = response.status
    except Exception as exc:
        status["online"] = False
        status["error"] = str(exc)
    return status


def normalize_project_priority(priority: str) -> str:
    value = priority.strip().lower()
    return value if value in ALLOWED_PROJECT_PRIORITIES else "normal"


def normalize_project_area(area: str) -> str:
    value = area.strip().lower()
    return value if value in ALLOWED_PROJECT_AREAS else "produto"


def normalize_slack_route(route: str, area: str) -> str:
    cleaned = route.strip().lower().lstrip("#")
    if cleaned in ALLOWED_ODESSA_CHANNELS:
        return cleaned
    if area == "qa":
        return "odessa-qa"
    if area == "docs":
        return "odessa-dev-log"
    if area in {"backend", "frontend", "runtime", "automacao"}:
        return "odessa-roadmap"
    return "odessa-roadmap"


def normalize_string_list(value: Any, fallback: list[str]) -> list[str]:
    if isinstance(value, list):
        items = [str(item).strip() for item in value if str(item).strip()]
        return items[:12] if items else fallback
    if isinstance(value, str) and value.strip():
        return [value.strip()]
    return fallback


def normalize_object_list(
    value: Any,
    fallback: list[dict[str, Any]],
    required_keys: tuple[str, ...],
) -> list[dict[str, Any]]:
    if not isinstance(value, list):
        return fallback
    items: list[dict[str, Any]] = []
    for index, item in enumerate(value[:16]):
        if isinstance(item, dict):
            normalized = {key: str(item.get(key) or "").strip() for key in required_keys}
            for key, val in item.items():
                if key not in normalized:
                    normalized[key] = val
        else:
            normalized = {required_keys[0]: str(item).strip()}
        if not normalized.get(required_keys[0]):
            normalized[required_keys[0]] = f"Item {index + 1}"
        items.append(normalized)
    return items or fallback


def normalize_project_plan(
    raw: dict[str, Any],
    request: ProjectCreatePlanRequest,
) -> dict[str, Any]:
    title = str(raw.get("title") or request.title).strip() or "Nova etapa Odessa"
    area = normalize_project_area(request.area)
    priority = normalize_project_priority(request.priority)
    slack_route = normalize_slack_route(str(raw.get("slackRoute") or request.targetChannel), area)
    fallback_task = {
        "id": "ODS-TASK-1",
        "title": "Refinar e executar o plano inicial",
        "area": area,
        "priority": priority,
        "status": "planned",
        "acceptanceCriteria": ["Plano revisado e aceito no Slack."],
    }
    return {
        "title": title,
        "summary": str(raw.get("summary") or request.brief[:420]).strip(),
        "goals": normalize_string_list(
            raw.get("goals"),
            ["Transformar o brief em uma etapa clara, priorizada e auditavel do Odessa."],
        ),
        "milestones": normalize_object_list(
            raw.get("milestones"),
            [{"id": "ODS-M1", "title": "Plano operacional aprovado", "outcome": "Backlog pronto para execucao."}],
            ("id", "title", "outcome"),
        ),
        "tasks": normalize_object_list(raw.get("tasks"), [fallback_task], ("id", "title", "area", "priority", "status")),
        "decisions": normalize_string_list(
            raw.get("decisions"),
            ["Manter o primeiro ciclo como planejamento e organizacao, sem geracao automatica de codigo."],
        ),
        "risks": normalize_string_list(
            raw.get("risks"),
            ["Escopo amplo demais pode prejudicar validacao rapida do MVP."],
        ),
        "acceptanceCriteria": normalize_string_list(
            raw.get("acceptanceCriteria"),
            ["Plano contem resumo, tarefas, decisoes, riscos e proximas acoes."],
        ),
        "slackRoute": slack_route,
        "nextActions": normalize_string_list(
            raw.get("nextActions"),
            ["Publicar resumo no Slack e escolher a primeira tarefa executavel."],
        ),
    }


def normalize_focus_areas(value: Optional[list[str]]) -> list[str]:
    fallback = ["runtime", "automacao", "qa", "docs"]
    if not value:
        return fallback
    areas = []
    for item in value[:8]:
        area = normalize_project_area(str(item))
        if area not in areas:
            areas.append(area)
    return areas or fallback


def normalize_night_shift_plan(
    raw: dict[str, Any],
    request: NightShiftRequest,
) -> dict[str, Any]:
    focus_areas = normalize_focus_areas(request.focusAreas)
    max_items = max(1, min(request.maxAdvancements, 8))
    fallback_advancement = {
        "id": "ODS-NS-1",
        "title": "Revisar proximo ciclo seguro",
        "area": focus_areas[0],
        "why": "Manter o projeto andando com organizacao e baixo risco.",
        "tasks": ["Revisar backlog", "Escolher primeira tarefa executavel"],
        "acceptanceCriteria": ["Brief de retorno contem proximas acoes claras."],
        "risk": "Escopo amplo demais para uma rodada sem supervisao.",
        "handoffPrompt": "Validar prioridades antes de executar codigo.",
    }
    advancements = normalize_object_list(
        raw.get("advancements"),
        [fallback_advancement],
        ("id", "title", "area", "why", "risk", "handoffPrompt"),
    )[:max_items]
    for index, advancement in enumerate(advancements):
        advancement["id"] = str(advancement.get("id") or f"ODS-NS-{index + 1}")
        advancement["area"] = normalize_project_area(str(advancement.get("area") or focus_areas[0]))
        advancement["tasks"] = normalize_string_list(
            advancement.get("tasks"),
            ["Transformar este avanco em tarefa executavel."],
        )
        advancement["acceptanceCriteria"] = normalize_string_list(
            advancement.get("acceptanceCriteria"),
            ["Criterio de aceite objetivo definido."],
        )

    return {
        "title": str(raw.get("title") or "Odessa Night Shift").strip(),
        "summary": str(
            raw.get("summary")
            or "Pacote seguro de avancos preparado para retomada do projeto."
        ).strip(),
        "safeMode": True,
        "durationMinutes": max(15, min(request.durationMinutes, 480)),
        "focusAreas": focus_areas,
        "advancements": advancements,
        "decisions": normalize_string_list(
            raw.get("decisions"),
            ["Nao executar alteracoes de codigo automaticamente durante a rodada sem supervisao."],
        ),
        "risks": normalize_string_list(
            raw.get("risks"),
            ["Automacao sem supervisao deve se limitar a planejamento, auditoria e preparacao."],
        ),
        "morningBrief": str(
            raw.get("morningBrief")
            or "Ao voltar, revise o pacote, escolha um avanco e execute com validacao."
        ).strip(),
        "slackRoute": normalize_slack_route(str(raw.get("slackRoute") or request.targetChannel), focus_areas[0]),
        "createdAt": utc_now(),
    }


def normalize_task_status(value: Any) -> str:
    status = str(value or "todo").strip().lower()
    return status if status in {"next", "todo", "in_progress", "blocked", "done"} else "todo"


def normalize_task_priority(value: Any) -> str:
    priority = str(value or "normal").strip().lower()
    return priority if priority in {"low", "normal", "high", "urgent"} else "normal"


def make_task_id(index: int) -> str:
    return f"ODS-TASK-{index + 1:03d}"


def normalize_project_task(raw: Any, index: int, fallback_area: str) -> dict[str, Any]:
    if not isinstance(raw, dict):
        raw = {"title": str(raw)}

    title = str(raw.get("title") or raw.get("name") or f"Tarefa {index + 1}").strip()
    task_id = str(raw.get("id") or make_task_id(index)).strip()
    area = normalize_project_area(str(raw.get("area") or fallback_area))
    priority = normalize_task_priority(raw.get("priority"))
    status = normalize_task_status(raw.get("status"))
    acceptance = normalize_string_list(
        raw.get("acceptanceCriteria"),
        ["Resultado verificavel e registrado no Odessa."],
    )
    depends_on = raw.get("dependsOn")
    if isinstance(depends_on, list):
        depends_on = [str(item).strip() for item in depends_on if str(item).strip()][:8]
    else:
        depends_on = []

    return {
        "id": task_id,
        "title": title,
        "area": area,
        "priority": priority,
        "status": status,
        "why": str(raw.get("why") or raw.get("reason") or "").strip(),
        "acceptanceCriteria": acceptance,
        "dependsOn": depends_on,
        "source": str(raw.get("source") or "continuous-organizer").strip(),
        "updatedAt": utc_now(),
    }


def merge_project_tasks(
    existing_tasks: list[dict[str, Any]],
    incoming_tasks: list[dict[str, Any]],
) -> list[dict[str, Any]]:
    merged: dict[str, dict[str, Any]] = {}
    for index, task in enumerate(existing_tasks):
        if not isinstance(task, dict):
            continue
        normalized = normalize_project_task(task, index, str(task.get("area") or "produto"))
        merged[normalized["id"]] = normalized

    next_index = len(merged)
    for task in incoming_tasks:
        normalized = normalize_project_task(task, next_index, str(task.get("area") or "produto"))
        next_index += 1
        existing = merged.get(normalized["id"])
        if existing and existing.get("status") in {"done", "in_progress"}:
            normalized["status"] = existing["status"]
        merged[normalized["id"]] = {**(existing or {}), **normalized}

    priority_rank = {"urgent": 0, "high": 1, "normal": 2, "low": 3}
    status_rank = {"next": 0, "in_progress": 1, "todo": 2, "blocked": 3, "done": 4}
    tasks = list(merged.values())
    tasks.sort(
        key=lambda item: (
            status_rank.get(str(item.get("status")), 5),
            priority_rank.get(str(item.get("priority")), 4),
            str(item.get("id") or ""),
        )
    )
    return tasks[:MAX_PROJECT_TASKS]


def fallback_continuous_organizer(
    request: ContinuousOrganizerRequest,
    focus_areas: list[str],
    current_tasks: list[dict[str, Any]],
    error: Optional[str] = None,
) -> dict[str, Any]:
    existing_open = [
        task
        for task in current_tasks
        if isinstance(task, dict) and normalize_task_status(task.get("status")) != "done"
    ][:4]
    tasks = existing_open or [
        {
            "id": "ODS-TASK-001",
            "title": "Validar fluxo Capture Studio -> Live Director -> fila de acoes",
            "area": "runtime",
            "priority": "urgent",
            "status": "next",
            "why": "Este e o fluxo central do produto final.",
            "acceptanceCriteria": [
                "Evento capturado aparece no Controle Live.",
                "Decisao da Persona gera uma acao auditavel.",
                "Resultado fica registrado em JSON.",
            ],
        },
        {
            "id": "ODS-TASK-002",
            "title": "Conectar Slack real ao n8n para registrar roadmap e QA",
            "area": "automacao",
            "priority": "high",
            "status": "todo",
            "why": "Sem Slack real, os workflows so preparam mensagens.",
            "acceptanceCriteria": [
                "N8N_SLACK_WEBHOOK_URL configurado.",
                "Project Organizer publica resumo no canal correto.",
            ],
        },
        {
            "id": "ODS-TASK-003",
            "title": "Definir criterios de produto final do Odessa MVP",
            "area": "produto",
            "priority": "high",
            "status": "todo",
            "why": "O runtime precisa de uma direcao objetiva ate o produto final.",
            "acceptanceCriteria": [
                "Lista de criterios finalizada.",
                "Cada criterio tem teste manual ou automatico associado.",
            ],
        },
    ]
    return {
        "summary": (
            "Organizacao continua executada em modo fallback local. "
            "Use esta lista como fila de proximas tarefas ate a IA estar disponivel."
        ),
        "currentPhase": "mvp-runtime-auditavel",
        "recommendedFocus": focus_areas[:3],
        "tasks": tasks[: max(1, min(request.maxTasks, 12))],
        "blocked": [],
        "risks": normalize_string_list(
            [error] if error else [],
            ["IA indisponivel pode reduzir a qualidade da priorizacao automatica."],
        ),
        "questions": [
            "Qual integracao real deve vir primeiro: Slack, OBS, media ou Tango Live?"
        ],
        "nextActions": [
            "Executar a primeira tarefa com status next.",
            "Registrar resultado no Controle Live ou Slack.",
        ],
    }


def normalize_continuous_organizer(
    raw: dict[str, Any],
    request: ContinuousOrganizerRequest,
    focus_areas: list[str],
) -> dict[str, Any]:
    max_tasks = max(1, min(request.maxTasks, 12))
    raw_tasks = raw.get("tasks")
    if not isinstance(raw_tasks, list):
        raw_tasks = fallback_continuous_organizer(request, focus_areas, [])["tasks"]
    tasks = [
        normalize_project_task(task, index, focus_areas[index % len(focus_areas)])
        for index, task in enumerate(raw_tasks[:max_tasks])
    ]
    if tasks and not any(task["status"] == "next" for task in tasks):
        tasks[0]["status"] = "next"

    return {
        "id": f"ods-organizer-run-{int(time.time() * 1000)}",
        "createdAt": utc_now(),
        "cadence": str(request.cadence or "scheduled_30m"),
        "summary": str(
            raw.get("summary")
            or "Rodada de organizacao continua concluida."
        ).strip(),
        "currentPhase": str(raw.get("currentPhase") or "mvp-runtime-auditavel").strip(),
        "recommendedFocus": normalize_string_list(raw.get("recommendedFocus"), focus_areas),
        "tasks": tasks,
        "blocked": normalize_string_list(raw.get("blocked"), []),
        "risks": normalize_string_list(raw.get("risks"), []),
        "questions": normalize_string_list(raw.get("questions"), []),
        "nextActions": normalize_string_list(
            raw.get("nextActions"),
            ["Executar a primeira tarefa com status next e registrar o resultado."],
        ),
        "slackRoute": normalize_slack_route(request.targetChannel, focus_areas[0]),
    }


def build_organizer_slack_message(organizer: dict[str, Any]) -> dict[str, Any]:
    tasks = organizer.get("tasks") if isinstance(organizer.get("tasks"), list) else []
    task_lines = []
    for task in tasks[:8]:
        task_lines.append(
            f"- *{task.get('id')}* [{task.get('status')}/{task.get('priority')}] "
            f"{task.get('title')}"
        )
    if not task_lines:
        task_lines.append("- Nenhuma tarefa priorizada nesta rodada.")

    risks = organizer.get("risks") if isinstance(organizer.get("risks"), list) else []
    risk_text = "\n".join(f"- {risk}" for risk in risks[:4]) or "- Sem riscos novos."
    next_actions = organizer.get("nextActions") if isinstance(organizer.get("nextActions"), list) else []
    action_text = "\n".join(f"- {action}" for action in next_actions[:4]) or "- Revisar fila de tarefas."
    channel = str(organizer.get("slackRoute") or "odessa-roadmap").lstrip("#")

    text = (
        f"*Odessa Continuous Organizer*\n{organizer.get('summary', '')}\n\n"
        f"*Tarefas priorizadas*\n" + "\n".join(task_lines) + "\n\n"
        f"*Riscos*\n{risk_text}\n\n"
        f"*Proximas acoes*\n{action_text}"
    )
    return {
        "channel": f"#{channel}",
        "text": text,
        "blocks": [
            {
                "type": "section",
                "text": {
                    "type": "mrkdwn",
                    "text": f"*Odessa Continuous Organizer*\n{organizer.get('summary', '')}",
                },
            },
            {
                "type": "section",
                "text": {"type": "mrkdwn", "text": "*Tarefas priorizadas*\n" + "\n".join(task_lines)},
            },
            {
                "type": "section",
                "text": {"type": "mrkdwn", "text": f"*Proximas acoes*\n{action_text}"},
            },
        ],
    }


def slugify_filename(value: str, fallback: str = "asset") -> str:
    cleaned = re.sub(r"[^a-zA-Z0-9_-]+", "-", value.strip().lower())
    cleaned = re.sub(r"-+", "-", cleaned).strip("-")
    return cleaned[:80] or fallback


def default_visual_references() -> list[VisualReference]:
    return [
        VisualReference(
            source="safe_seed",
            notes=(
                "Mobile social live aesthetic: vertical framing, warm host energy, "
                "gift animations, compact bedroom/studio setups, colorful LED accents, "
                "clear face lighting, expressive hand gestures and direct camera presence."
            ),
        ),
        VisualReference(
            source="safe_seed",
            notes=(
                "Tango Live audience context without copying creators: high interaction, "
                "gratitude for gifts, upbeat conversation, intimate live-room atmosphere, "
                "playful overlays and fast visual feedback."
            ),
        ),
    ]


def normalize_visual_reference(reference: VisualReference) -> dict[str, Any]:
    metadata = reference.metadata if isinstance(reference.metadata, dict) else {}
    url = str(reference.url or "").strip()
    safe_metadata = {
        key: value
        for key, value in metadata.items()
        if key not in {"username", "handle", "displayName", "profileUrl", "faceId"}
    }
    if url:
        safe_metadata["referenceUrlProvided"] = True

    return {
        "source": str(reference.source or "manual").strip()[:80],
        "notes": str(reference.notes or "").strip()[:1800],
        "observedAt": str(reference.observedAt or utc_now()),
        "metadata": safe_metadata,
        "privacy": "identity_redacted",
    }


def normalize_visual_asset_request(
    raw: Any,
    index: int,
    fallback_aspect_ratio: str,
) -> dict[str, Any]:
    if not isinstance(raw, dict):
        raw = {"prompt": str(raw)}

    allowed_kinds = {
        "persona_portrait",
        "persona_angle",
        "persona_action",
        "environment",
        "scene_background",
        "overlay_concept",
    }
    kind = str(raw.get("kind") or "persona_action").strip()
    if kind not in allowed_kinds:
        kind = "persona_action"

    asset_id = slugify_filename(str(raw.get("id") or f"visual-{index + 1}"), f"visual-{index + 1}")
    title = str(raw.get("title") or f"Visual asset {index + 1}").strip()
    prompt = str(raw.get("prompt") or "").strip()
    if not prompt:
        prompt = (
            "Create an original vertical social live visual for Odessa/Juju, a fictional "
            "AI live host, with warm lighting, expressive posture and a modern streaming room."
        )

    safety_suffix = (
        " Safety constraints: original fictional character only; do not recreate, imitate "
        "or identify any real Tango Live creator; no usernames, no logos, no exact face, "
        "no recognizable tattoos, no deepfake likeness, no sexualized minors."
    )
    if "original fictional" not in prompt.lower():
        prompt = prompt.rstrip(".") + "." + safety_suffix

    negative_prompt = str(
        raw.get("negativePrompt")
        or "real person likeness, copied face, username, platform logo, low quality, distorted hands"
    ).strip()
    aspect_ratio = str(raw.get("aspectRatio") or fallback_aspect_ratio or "9:16").strip()
    priority = str(raw.get("priority") or "normal").strip().lower()
    if priority not in {"low", "normal", "high", "urgent"}:
        priority = "normal"

    return {
        "id": asset_id,
        "kind": kind,
        "title": title,
        "prompt": prompt,
        "negativePrompt": negative_prompt,
        "aspectRatio": aspect_ratio,
        "priority": priority,
        "status": "prompt_ready",
    }


