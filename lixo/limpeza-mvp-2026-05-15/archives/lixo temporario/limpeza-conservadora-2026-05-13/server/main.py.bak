def normalize_visual_plan(
    raw: dict[str, Any],
    request: VisualAssetRunRequest,
    references: list[dict[str, Any]],
) -> dict[str, Any]:
    fallback = fallback_visual_plan(request)
    asset_requests = raw.get("assetRequests")
    if not isinstance(asset_requests, list):
        asset_requests = fallback["assetRequests"]

    normalized_assets = [
        normalize_visual_asset_request(asset, index, request.aspectRatio)
        for index, asset in enumerate(asset_requests[: max(1, min(request.maxPrompts, 12))])
    ]

    return {
        "summary": str(raw.get("summary") or fallback["summary"]).strip(),
        "sourceNotes": normalize_string_list(raw.get("sourceNotes"), fallback["sourceNotes"]),
        "personaDirection": raw.get("personaDirection")
        if isinstance(raw.get("personaDirection"), dict)
        else fallback["personaDirection"],
        "assetRequests": normalized_assets,
        "safetyNotes": normalize_string_list(raw.get("safetyNotes"), fallback["safetyNotes"]),
        "nextLoopSuggestion": str(
            raw.get("nextLoopSuggestion") or fallback["nextLoopSuggestion"]
        ).strip(),
        "referencesUsed": references,
    }


def build_visual_asset_slack_message(run: dict[str, Any]) -> dict[str, Any]:
    plan = run.get("plan") if isinstance(run.get("plan"), dict) else {}
    assets = run.get("assets") if isinstance(run.get("assets"), list) else []
    generated = [asset for asset in assets if asset.get("status") == "generated"]
    errors = [asset for asset in assets if asset.get("status") == "error"]
    prompt_lines = []
    for asset in assets[:6]:
        prompt_lines.append(
            f"- *{asset.get('id')}* [{asset.get('kind')}/{asset.get('status')}] "
            f"{asset.get('title')}"
        )
    if not prompt_lines:
        prompt_lines.append("- Nenhum prompt gerado.")

    text = (
        f"*Odessa Visual Asset Generator*\n"
        f"{plan.get('summary', 'Rodada visual concluida.')}\n\n"
        f"*Run*: `{run.get('runId')}`\n"
        f"*Imagens geradas*: {len(generated)} / {len(assets)}\n"
        f"*Erros*: {len(errors)}\n"
        f"*Pasta*: `{run.get('outputDir')}`\n\n"
        f"*Assets*\n" + "\n".join(prompt_lines) + "\n\n"
        f"*Proxima rodada*\n{plan.get('nextLoopSuggestion', 'Revisar prompts e escolher variacoes.')}"
    )
    return {
        "channel": f"#{str(run.get('slackRoute') or 'odessa-roadmap').lstrip('#')}",
        "text": text,
    }


def generate_gemini_image_asset(
    *,
    prompt: str,
    output_path: Path,
    model: str,
    aspect_ratio: str,
    image_size: str,
) -> dict[str, Any]:
    if not gemini_client:
        raise RuntimeError("GEMINI_API_KEY is not configured for image generation")

    image_config_kwargs: dict[str, Any] = {}
    if aspect_ratio:
        image_config_kwargs["aspect_ratio"] = aspect_ratio
    if image_size:
        image_config_kwargs["image_size"] = image_size

    config_kwargs: dict[str, Any] = {"response_modalities": ["TEXT", "IMAGE"]}
    if image_config_kwargs:
        config_kwargs["image_config"] = genai_types.ImageConfig(**image_config_kwargs)

    response = gemini_client.models.generate_content(
        model=model,
        contents=[prompt],
        config=genai_types.GenerateContentConfig(**config_kwargs),
    )

    text_parts: list[str] = []
    parts = []
    if getattr(response, "candidates", None):
        candidate = response.candidates[0]
        content = getattr(candidate, "content", None)
        parts = list(getattr(content, "parts", []) or [])

    for part in parts:
        text = getattr(part, "text", None)
        if text:
            text_parts.append(str(text).strip())

        inline_data = getattr(part, "inline_data", None)
        data = getattr(inline_data, "data", None) if inline_data else None
        if not data:
            continue

        mime_type = str(getattr(inline_data, "mime_type", "image/png") or "image/png")
        extension = ".jpg" if "jpeg" in mime_type else ".png"
        if output_path.suffix.lower() != extension:
            output_path = output_path.with_suffix(extension)

        image_bytes = data if isinstance(data, bytes) else base64.b64decode(data)
        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_bytes(image_bytes)
        return {
            "path": str(output_path),
            "mimeType": mime_type,
            "bytes": len(image_bytes),
            "modelText": "\n".join(text_parts).strip(),
        }

    raise RuntimeError("Gemini image model returned no image data")


def openai_image_size_for_aspect(aspect_ratio: str) -> str:
    if OPENAI_IMAGE_SIZE:
        return OPENAI_IMAGE_SIZE

    value = str(aspect_ratio or "").strip().lower()
    vertical_ratios = {"9:16", "2:3", "3:4", "4:5", "1:2"}
    horizontal_ratios = {"16:9", "3:2", "4:3", "5:4", "21:9", "2:1"}
    if value in vertical_ratios:
        return "1024x1536"
    if value in horizontal_ratios:
        return "1536x1024"
    if value == "1:1":
        return "1024x1024"
    return "auto"


def generate_openai_image_asset(
    *,
    prompt: str,
    output_path: Path,
    model: str,
    aspect_ratio: str,
) -> dict[str, Any]:
    if not openai_client:
        raise RuntimeError("OPENAI_API_KEY is not configured for image generation")

    image_model = model or OPENAI_IMAGE_MODEL
    size = openai_image_size_for_aspect(aspect_ratio)
    kwargs: dict[str, Any] = {
        "model": image_model,
        "prompt": prompt,
        "n": 1,
        "size": size,
    }
    if image_model.startswith("gpt-image"):
        kwargs["quality"] = OPENAI_IMAGE_QUALITY or "auto"
        kwargs["output_format"] = "png"
    else:
        kwargs["response_format"] = "b64_json"
        if OPENAI_IMAGE_QUALITY in {"standard", "hd"}:
            kwargs["quality"] = OPENAI_IMAGE_QUALITY

    response = openai_client.images.generate(**kwargs)
    if not getattr(response, "data", None):
        raise RuntimeError("OpenAI image model returned no image data")

    image_item = response.data[0]
    b64_json = getattr(image_item, "b64_json", None)
    image_url = getattr(image_item, "url", None)
    revised_prompt = getattr(image_item, "revised_prompt", None)

    output_path = output_path.with_suffix(".png")
    output_path.parent.mkdir(parents=True, exist_ok=True)

    if b64_json:
        image_bytes = base64.b64decode(b64_json)
    elif image_url:
        with url_request.urlopen(str(image_url), timeout=30) as response_body:
            image_bytes = response_body.read()
    else:
        raise RuntimeError("OpenAI image response had neither b64_json nor url")

    output_path.write_bytes(image_bytes)
    return {
        "path": str(output_path),
        "mimeType": "image/png",
        "bytes": len(image_bytes),
        "modelText": str(revised_prompt or "").strip(),
        "size": size,
    }


def generate_visual_image_asset(
    *,
    prompt: str,
    output_path: Path,
    provider_preference: str,
    gemini_model: str,
    openai_model: str,
    aspect_ratio: str,
    image_size: str,
) -> dict[str, Any]:
    preference = str(provider_preference or "auto").strip().lower()
    if preference not in {"auto", "gemini", "openai"}:
        preference = "auto"

    provider_order = ["gemini", "openai"]
    if preference == "openai":
        provider_order = ["openai"]
    elif preference == "gemini":
        provider_order = ["gemini"]

    errors: list[str] = []
    for provider in provider_order:
        try:
            if provider == "gemini":
                result = generate_gemini_image_asset(
                    prompt=prompt,
                    output_path=output_path,
                    model=gemini_model,
                    aspect_ratio=aspect_ratio,
                    image_size=image_size,
                )
            else:
                result = generate_openai_image_asset(
                    prompt=prompt,
                    output_path=output_path,
                    model=openai_model,
                    aspect_ratio=aspect_ratio,
                )
            return {
                **result,
                "provider": provider,
                "model": gemini_model if provider == "gemini" else openai_model,
                "fallbackErrors": errors,
            }
        except Exception as exc:
            message = f"{provider}: {exc}"
            logger.warning("[VISUAL IMAGE %s ERROR] %s", provider.upper(), exc, exc_info=True)
            errors.append(message)

    raise RuntimeError("; ".join(errors) or "No image provider available")


def get_new_text(prev_text: str, current_text: str) -> str:
    if not prev_text:
        return current_text

    max_len = min(len(prev_text), 50)
    for length in range(max_len, 9, -1):
        suffix = prev_text[-length:]
        idx = current_text.find(suffix)
        if idx != -1:
            return current_text[idx + length :].strip()

    if abs(len(prev_text) - len(current_text)) < 10:
        return ""

    return current_text


def save_to_log(text: str) -> None:
    try:
        LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
        if LOG_FILE.exists():
            lines = LOG_FILE.read_text(encoding="utf-8").splitlines()
            if lines and text.strip() in lines[-1]:
                return

        with LOG_FILE.open("a", encoding="utf-8") as file:
            file.write(f"{text}\n")
        logger.info("Saved capture log entry")
    except Exception as exc:
        logger.error("Error saving capture log: %s", exc)


def cleanup_temp_file(path: str) -> None:
    try:
        Path(path).unlink(missing_ok=True)
    except Exception as exc:
        logger.warning("Could not remove temp file %s: %s", path, exc)


def package_installed(package: str) -> bool:
    return importlib.util.find_spec(package) is not None


def espeak_ng_path() -> Optional[str]:
    candidates = [
        ESPEAK_NG_PATH,
        shutil.which("espeak-ng") or "",
        r"C:\Program Files\eSpeak NG\espeak-ng.exe",
        r"C:\Program Files (x86)\eSpeak NG\espeak-ng.exe",
    ]
    for candidate in candidates:
        if candidate and Path(candidate).exists():
            return str(Path(candidate))
    return None


def ensure_espeak_on_path() -> None:
    path = espeak_ng_path()
    if not path:
        return
    folder = str(Path(path).parent)
    current = os.environ.get("PATH", "")
    if folder.lower() not in current.lower():
        os.environ["PATH"] = f"{folder}{os.pathsep}{current}"


def kokoro_available() -> bool:
    ensure_espeak_on_path()
    return KOKORO_ENABLED and package_installed("kokoro") and bool(espeak_ng_path())


def infer_tts_provider(raw_provider: Any, voice: str) -> str:
    provider = str(raw_provider or "auto").strip().lower()
    if provider not in {"auto", "edge", "openai", "kokoro"}:
        provider = "auto"

    voice_key = voice.replace("kokoro:", "").strip()
    if provider == "auto":
        if voice_key in OPENAI_TTS_VOICES:
            return "openai"
        if voice_key in KOKORO_VOICES:
            return "kokoro"
        if TTS_DEFAULT_PROVIDER in {"edge", "openai", "kokoro"} and not voice_key:
            return TTS_DEFAULT_PROVIDER
        return "edge"
    return provider


def default_voice_for_provider(provider: str, requested_voice: str) -> str:
    voice = str(requested_voice or "").replace("kokoro:", "").strip()
    if voice:
        return voice
    if provider == "openai":
        return "nova"
    if provider == "kokoro":
        return KOKORO_DEFAULT_VOICE
    return "pt-BR-FranciscaNeural"


def edge_rate_from_speed(speed: float) -> str:
    percent = int(round((speed - 1.0) * 100))
    return f"{percent:+d}%"


def edge_pitch_from_value(pitch: float) -> str:
    # edge-tts expects pitch as a signed Hz offset. The UI stores a gentle -12..12 scale.
    hz_offset = int(round(pitch * 8))
    return f"{hz_offset:+d}Hz"


def get_kokoro_pipeline(lang_code: str) -> Any:
    ensure_espeak_on_path()
    if not KOKORO_ENABLED:
        raise RuntimeError("Kokoro is disabled by KOKORO_ENABLED")
    if not package_installed("kokoro"):
        raise RuntimeError("kokoro is not installed in the Python environment")
    if not espeak_ng_path():
        raise RuntimeError("espeak-ng was not found on PATH")

    lang = lang_code or KOKORO_DEFAULT_LANG
    if lang not in kokoro_pipelines:
        from kokoro import KPipeline

        kokoro_pipelines[lang] = KPipeline(lang_code=lang)
    return kokoro_pipelines[lang]


def generate_kokoro_wav(text: str, voice: str, speed: float, output_path: str) -> None:
    voice_key = voice.replace("kokoro:", "").strip() or KOKORO_DEFAULT_VOICE
    voice_meta = KOKORO_VOICES.get(voice_key, {})
    lang_code = str(voice_meta.get("lang") or KOKORO_DEFAULT_LANG)
    pipeline = get_kokoro_pipeline(lang_code)
    generator = pipeline(text, voice=voice_key, speed=speed, split_pattern=r"\n+")
    chunks: list[np.ndarray] = []
    for _, _, audio in generator:
        if hasattr(audio, "detach"):
            audio = audio.detach().cpu().numpy()
        chunks.append(np.asarray(audio, dtype=np.float32))

    if not chunks:
        raise RuntimeError("Kokoro returned no audio")

    waveform = chunks[0] if len(chunks) == 1 else np.concatenate(chunks)
    import soundfile as sf

    sf.write(output_path, waveform, 24000)


def edge_voice_label(raw: dict[str, Any]) -> str:
    short_name = str(raw.get("ShortName") or "")
    local_name = str(raw.get("LocalName") or raw.get("FriendlyName") or short_name)
    if local_name and local_name != short_name:
        return local_name
    parts = short_name.split("-")
    return parts[-1].replace("Neural", "") if parts else short_name


def load_edge_voices() -> list[dict[str, Any]]:
    now = time.time()
    cached = edge_voice_cache.get("voices")
    if cached and now - float(edge_voice_cache.get("loaded_at") or 0) < 3600:
        return list(cached)

    try:
        voices = asyncio.run(edge_tts.list_voices())
        edge_voice_cache["voices"] = voices
        edge_voice_cache["loaded_at"] = now
        return voices
    except Exception as exc:
        logger.warning("Could not load Edge voices dynamically: %s", exc)
        return [
            {"ShortName": voice_id, "Gender": "Unknown", "Locale": "-".join(voice_id.split("-")[:2])}
            for voice_id in EDGE_TTS_VOICES
        ]


def voice_enabled(provider: str, meta: dict[str, Any]) -> bool:
    if provider == "edge":
        return True
    if provider == "openai":
        return bool(openai_client)
    if provider == "kokoro":
        return kokoro_available() and not meta.get("disabled_reason") and meta.get("lang") not in KOKORO_DISABLED_LANGS
    return False


def extract_json_object(text: str) -> dict:
    cleaned = text.strip()
    if cleaned.startswith("```"):
      cleaned = cleaned.strip("`")
      if cleaned.lower().startswith("json"):
          cleaned = cleaned[4:].strip()

    try:
        return json.loads(cleaned)
    except json.JSONDecodeError:
        start = cleaned.find("{")
        end = cleaned.rfind("}")
        if start == -1 or end == -1 or end <= start:
            raise
        return json.loads(cleaned[start : end + 1])


def normalize_decision(raw: dict, fallback_text: str) -> dict:
    speech = str(raw.get("speech") or "").strip()
    if not speech:
        speech = "Vou acompanhar isso agora e manter a live fluindo."

    intent = str(raw.get("intent") or "respond_live_event").strip()
    reason = str(raw.get("reason") or "Decisao baseada no evento recebido.").strip()
    priority = str(raw.get("priority") or "normal").strip().lower()
    if priority not in {"low", "normal", "high", "urgent"}:
        priority = "normal"

    try:
        confidence = float(raw.get("confidence", 0.7))
    except (TypeError, ValueError):
        confidence = 0.7
    confidence = max(0, min(1, confidence))

    actions = raw.get("actions")
    normalized_actions = []
    if isinstance(actions, list):
        for index, action in enumerate(actions):
            if not isinstance(action, dict):
                continue
            action_type = str(action.get("type") or "log_event").strip()
            if action_type not in ALLOWED_ACTIONS:
                action_type = "log_event"
            label = str(action.get("label") or action_type).strip()
            payload = action.get("payload")
            if not isinstance(payload, dict):
                payload = {}
            normalized_actions.append(
                {
                    "id": str(action.get("id") or f"action-{index + 1}"),
                    "type": action_type,
                    "label": label,
                    "capability": action.get("capability"),
                    "payload": payload,
                    "simulated": action_type != "speak",
                    "requiresApproval": bool(action.get("requiresApproval", False)),
                    "status": "queued",
                }
            )

    if not any(action["type"] == "speak" for action in normalized_actions):
        normalized_actions.insert(
            0,
            {
                "id": "action-speak",
                "type": "speak",
                "label": "Falar via TTS",
                "capability": "tts.speak",
                "payload": {"text": speech},
                "simulated": False,
                "requiresApproval": False,
                "status": "queued",
            },
        )

    if not normalized_actions:
        normalized_actions.append(
            {
                "id": "action-log",
                "type": "log_event",
                "label": "Registrar evento",
                "capability": "log.event",
                "payload": {"message": fallback_text},
                "simulated": True,
                "requiresApproval": False,
                "status": "queued",
            }
        )

    return {
        "speech": speech,
        "intent": intent,
        "confidence": confidence,
        "reason": reason,
        "priority": priority,
        "actions": normalized_actions,
    }


def generate_openai_text(
    system_prompt: str,
    user_prompt: str,
    temperature: float,
    *,
    json_mode: bool = False,
) -> str:
    if not openai_client:
        raise RuntimeError("OPENAI_API_KEY is not configured on the backend")

    kwargs: dict[str, Any] = {
        "model": OPENAI_TEXT_MODEL,
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_prompt},
        ],
        "temperature": temperature,
    }
    if json_mode:
        kwargs["response_format"] = {"type": "json_object"}

    response = openai_client.chat.completions.create(**kwargs)
    return response.choices[0].message.content or ""


def generate_ai_text_with_fallback(
    *,
    gemini_model: str,
    system_prompt: str,
    user_prompt: str,
    temperature: float,
    json_mode: bool = False,
) -> tuple[str, str]:
    errors: list[str] = []

    if gemini_client:
        try:
            config: dict[str, Any] = {
                "system_instruction": system_prompt,
                "temperature": temperature,
            }
            if json_mode:
                config["response_mime_type"] = "application/json"

            result = gemini_client.models.generate_content(
                model=gemini_model,
                contents=user_prompt,
                config=config,
            )
            text = result.text or ""
            if not text.strip():
                raise RuntimeError("Gemini returned an empty response")
            return text, "gemini"
        except Exception as exc:
            logger.warning("[GEMINI FALLBACK] %s", exc, exc_info=True)
            errors.append(f"Gemini: {exc}")
    else:
        errors.append("Gemini: GEMINI_API_KEY is not configured")

    if openai_client:
        try:
            text = generate_openai_text(
                system_prompt,
                user_prompt,
                temperature,
                json_mode=json_mode,
            )
            if not text.strip():
                raise RuntimeError("OpenAI returned an empty response")
            return text, "openai"
        except Exception as exc:
            logger.error("[OPENAI FALLBACK EXCEPTION] %s", exc, exc_info=True)
            errors.append(f"OpenAI: {exc}")
    else:
        errors.append("OpenAI: OPENAI_API_KEY is not configured")

    status_code = 503 if not (gemini_client or openai_client) else 502
    raise HTTPException(status_code=status_code, detail="; ".join(errors))


def load_regions() -> tuple[tuple[int, int, int, int], tuple[int, int, int, int]]:
    if REGION_FILE.exists():
        try:
            import json

            data = json.loads(REGION_FILE.read_text(encoding="utf-8"))
            return (
                tuple(data.get("chat_region", DEFAULT_CHAT_REGION)),
                tuple(data.get("gifts_region", DEFAULT_GIFTS_REGION)),
            )
        except Exception as exc:
            logger.warning("Cannot load %s: %s", REGION_FILE, exc)
    return DEFAULT_CHAT_REGION, DEFAULT_GIFTS_REGION


def decode_request_image(image_data: str) -> bytes:
    img_data = image_data.split(",", 1)[1] if "," in image_data else image_data
    img_data = "".join(img_data.split())
    estimated_bytes = (len(img_data) * 3) // 4
    if estimated_bytes > MAX_OCR_IMAGE_BYTES:
        raise HTTPException(
            status_code=413,
            detail=f"Image is too large for OCR. Limit is {MAX_OCR_IMAGE_BYTES} bytes.",
        )

    try:
        image_bytes = base64.b64decode(img_data, validate=True)
    except (binascii.Error, ValueError) as exc:
        raise HTTPException(status_code=400, detail="Invalid base64 image payload") from exc

    if len(image_bytes) > MAX_OCR_IMAGE_BYTES:
        raise HTTPException(
            status_code=413,
            detail=f"Image is too large for OCR. Limit is {MAX_OCR_IMAGE_BYTES} bytes.",
        )
    return image_bytes


def validate_ocr_dimensions(width: int, height: int) -> None:
    if width * height > MAX_OCR_IMAGE_PIXELS:
        raise HTTPException(
            status_code=413,
            detail=f"Image dimensions are too large for OCR. Limit is {MAX_OCR_IMAGE_PIXELS} pixels.",
        )


def image_from_request(request: RegionRequest) -> np.ndarray:
    if request.image:
        image_bytes = decode_request_image(request.image)
        try:
            with Image.open(io.BytesIO(image_bytes)) as image:
                validate_ocr_dimensions(image.width, image.height)
                return np.array(image.convert("RGB"))
        except (UnidentifiedImageError, OSError, Image.DecompressionBombError) as exc:
            raise HTTPException(status_code=400, detail="Invalid image payload") from exc

    if (
        request.x is None
        or request.y is None
        or request.width is None
        or request.height is None
        or request.width <= 0
        or request.height <= 0
    ):
        raise HTTPException(status_code=400, detail="Invalid dimensions or missing image")

    validate_ocr_dimensions(request.width, request.height)

    screenshot = pyautogui.screenshot(
        region=(request.x, request.y, request.width, request.height)
    )
    return np.array(screenshot)


@app.get("/health")
def health_check():
    return {
        "status": "ok",
        "ocr": "ready",
        "gemini_configured": bool(GEMINI_API_KEY),
        "gemini_image_model": GEMINI_IMAGE_MODEL,
        "gemini_image_configured": bool(GEMINI_API_KEY),
        "openai_ai_configured": bool(OPENAI_API_KEY),
        "openai_text_model": OPENAI_TEXT_MODEL,
        "openai_image_model": OPENAI_IMAGE_MODEL,
        "openai_image_configured": bool(OPENAI_API_KEY),
        "openai_tts_configured": bool(OPENAI_API_KEY),
        "tts_default_provider": TTS_DEFAULT_PROVIDER,
        "kokoro_enabled": KOKORO_ENABLED,
        "kokoro_package_installed": package_installed("kokoro"),
        "kokoro_espeak_configured": bool(espeak_ng_path()),
        "kokoro_espeak_path": espeak_ng_path(),
        "kokoro_tts_configured": kokoro_available(),
        "kokoro_default_voice": KOKORO_DEFAULT_VOICE,
        "n8n": n8n_health(),
        "obs": {
            "configured": bool(N8N_ACTION_WEBHOOK_URL),
            "source": "n8n",
            "scene_whitelist": "automatic",
        },
        "memory": get_memory_stats(),
    }


@app.get("/")
def read_root():
    return {"message": "Odessa local capture API is running"}


@app.post("/n8n/events")
async def ingest_n8n_events(request: Request):
    verify_n8n_secret(request)
    try:
        data = await request.json()
    except Exception as exc:
        raise HTTPException(status_code=400, detail="Invalid JSON payload") from exc

    if isinstance(data, dict) and isinstance(data.get("events"), list):
        raw_events = data["events"]
    elif isinstance(data, dict) and data.get("event") is not None:
        raw_events = [data["event"]]
    elif isinstance(data, list):
        raw_events = data
    else:
        raw_events = [data]

    events = [normalize_n8n_event(raw, index) for index, raw in enumerate(raw_events)]
    if not events:
        raise HTTPException(status_code=400, detail="No events provided")

    queue = read_json_list(N8N_EVENT_QUEUE_FILE)
    queue.extend(events)
    queue = queue[-MAX_N8N_QUEUE_EVENTS:]
    write_json_list(N8N_EVENT_QUEUE_FILE, queue)
    append_n8n_audit(
        "event_ingest",
        {"events": events},
        {"accepted": len(events), "queued": len(queue)},
    )
    return {"accepted": len(events), "queued": len(queue), "events": events}


@app.get("/n8n/events")
def consume_n8n_events(limit: int = 20):
    safe_limit = max(1, min(limit, 50))
    queue = read_json_list(N8N_EVENT_QUEUE_FILE)
    batch = queue[:safe_limit]
    remaining = queue[safe_limit:]
    if batch:
        write_json_list(N8N_EVENT_QUEUE_FILE, remaining)
    return {"events": batch, "remaining": len(remaining)}


@app.get("/obs/scenes")
def get_obs_scenes():
    if not N8N_ACTION_WEBHOOK_URL:
        return {
            "ok": False,
            "scenes": [],
            "currentScene": None,
            "source": "n8n",
            "error": "N8N_ACTION_WEBHOOK_URL is not configured",
        }

    payload = {
        "product": "Odessa",
        "target": "action",
        "createdAt": utc_now(),
        "payload": {
            "action": {
                "id": "obs-list-scenes",
                "type": "log_event",
                "label": "Listar cenas OBS",
                "capability": "obs.list_scenes",
                "payload": {},
                "simulated": False,
                "requiresApproval": False,
            },
            "tool": {
                "id": "tool-obs-scene",
                "label": "OBS WebSocket via n8n",
                "capability": "obs.list_scenes",
                "simulated": False,
            },
            "decision": {"intent": "discover_obs_scenes"},
        },
    }
    try:
        result = post_json_to_n8n(N8N_ACTION_WEBHOOK_URL, payload)
        parsed = parse_json_body(result.get("body"))
        scenes, current_scene = extract_scene_list(parsed)
        return {
            "ok": bool(scenes or current_scene),
            "scenes": scenes,
            "currentScene": current_scene,
            "source": "n8n",
            "status_code": result.get("status_code"),
            "response": parsed,
            "error": None if scenes or current_scene else "n8n did not return OBS scenes",
        }
    except HTTPException as exc:
        return {
            "ok": False,
            "scenes": [],
            "currentScene": None,
            "source": "n8n",
            "error": exc.detail,
        }


@app.post("/memory/round-context")
def create_memory_round_context(request: MemoryRoundContextRequest):
    events = [model_payload(event) for event in request.events]
    return upsert_round_memory(events)


@app.get("/memory/stats")
def read_memory_stats():
    return get_memory_stats()


@app.post("/n8n/dispatch")
def dispatch_to_n8n(dispatch_request: N8NDispatchRequest):
    target = dispatch_request.target.strip().lower()
    urls = {
        "audit": N8N_AUDIT_WEBHOOK_URL,
        "action": N8N_ACTION_WEBHOOK_URL,
        "event": N8N_EVENT_INGEST_WEBHOOK_URL,
        "visual": N8N_VISUAL_ASSET_WEBHOOK_URL,
    }
    if target not in urls:
        raise HTTPException(status_code=400, detail="Invalid n8n target")

    payload = {
        "product": "Odessa",
        "target": target,
        "createdAt": utc_now(),
        "payload": dispatch_request.payload,
    }
    webhook_url = urls[target]
    if not webhook_url:
        append_n8n_audit(
            f"{target}_dispatch_skipped",
            payload,
            {"ok": False, "reason": "webhook_not_configured"},
        )
        raise HTTPException(status_code=503, detail=f"N8N {target} webhook is not configured")

    try:
        result = post_json_to_n8n(webhook_url, payload)
    except HTTPException as exc:
        append_n8n_audit(
            f"{target}_dispatch_error",
            payload,
            {"ok": False, "error": exc.detail},
        )
        raise

    parsed = parse_json_body(result.get("body"))
    if isinstance(parsed, list) and len(parsed) == 1 and isinstance(parsed[0], dict):
        parsed = parsed[0]

    response: dict[str, Any] = {"ok": True, "target": target, **result}
    if parsed is not None:
        response["response"] = parsed
    if isinstance(parsed, dict):
        for key in (
            "executed",
            "simulated",
            "capability",
            "scene",
            "currentScene",
            "scenes",
            "status",
            "message",
            "error",
        ):
            if key in parsed:
                response[key] = parsed[key]

    append_n8n_audit(f"{target}_dispatch", payload, response)
    return response


