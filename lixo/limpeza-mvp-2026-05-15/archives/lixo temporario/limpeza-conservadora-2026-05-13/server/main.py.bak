@app.post("/visual-lab/run")
def run_visual_asset_generator(request: VisualAssetRunRequest):
    max_prompts = max(1, min(request.maxPrompts, 12))
    max_images = max(0, min(request.maxImages, MAX_VISUAL_IMAGES_PER_RUN))
    target_channel = normalize_slack_route(request.targetChannel, "automacao")
    references = [
        normalize_visual_reference(reference)
        for reference in (request.references or default_visual_references())
    ][:12]
    run_id = f"ods-visual-{int(time.time() * 1000)}"
    output_dir = ODESSA_VISUAL_OUTPUT_DIR / run_id
    output_dir.mkdir(parents=True, exist_ok=True)

    contract = {
        "summary": "resumo curto da rodada visual",
        "sourceNotes": ["tendencia visual anonima observada"],
        "personaDirection": {
            "name": "Odessa/Juju",
            "visualTone": "calorosa, social live, energetica",
            "wardrobe": "direcao de figurino",
            "environment": "direcao de cenario",
        },
        "assetRequests": [
            {
                "id": "odessa-asset-1",
                "kind": "persona_portrait | persona_angle | persona_action | environment | scene_background | overlay_concept",
                "title": "nome curto do asset",
                "prompt": "prompt de imagem detalhado em ingles",
                "negativePrompt": "elementos que devem ser evitados",
                "aspectRatio": request.aspectRatio or "9:16",
                "priority": "low | normal | high | urgent",
            }
        ],
        "safetyNotes": ["limite de seguranca visual"],
        "nextLoopSuggestion": "o que observar ou gerar na proxima rodada",
    }
    user_payload = {
        "objective": request.objective,
        "mode": request.mode,
        "seedPersona": request.seedPersona,
        "requestedBy": request.requestedBy,
        "maxPrompts": max_prompts,
        "maxImages": max_images,
        "imageProvider": request.imageProvider,
        "references": references,
        "productContext": (
            "Odessa e uma persona IA para lives sociais. O Visual Lab cria assets "
            "originais para ambientes, poses, reacoes e cenas da persona."
        ),
    }
    system_prompt = (
        "Voce e o diretor visual seguro do Odessa. Transforme observacoes anonimas "
        "de lives sociais em prompts originais de imagem para uma persona ficticia. "
        "Nao copie criadoras reais, nao cite nomes, nao replique rostos, tatuagens, "
        "quartos identificaveis, handles, logos ou qualquer identidade pessoal. "
        "Use referencias reais apenas como linguagem visual de alto nivel. "
        "Responda somente JSON valido."
    )
    user_prompt = (
        "Crie uma rodada de assets visuais para Odessa/Juju com este contexto:\n"
        f"{json.dumps(user_payload, ensure_ascii=False)}\n\n"
        "Retorne APENAS um objeto JSON valido seguindo este contrato:\n"
        f"{json.dumps(contract, ensure_ascii=False)}\n\n"
        "Regras:\n"
        "- Escreva metadados em portugues do Brasil.\n"
        "- Escreva os prompts de imagem em ingles, claros e completos.\n"
        "- Gere prompts para persona de frente, angulo lateral, acao em live e cenario.\n"
        "- Priorize formato vertical 9:16 para uso em live mobile.\n"
        "- Nunca gere prompt para copiar uma pessoa real do Tango Live."
    )

    provider = "local-fallback"
    try:
        text, provider = generate_ai_text_with_fallback(
            gemini_model=request.model,
            system_prompt=system_prompt,
            user_prompt=user_prompt,
            temperature=request.temperature,
            json_mode=True,
        )
        parsed = extract_json_object(text or "{}")
    except Exception as exc:
        logger.warning("[VISUAL LAB PLAN FALLBACK] %s", exc, exc_info=True)
        parsed = fallback_visual_plan(request)
        provider = "local-fallback"

    plan = normalize_visual_plan(parsed, request, references)
    assets = [dict(asset) for asset in plan["assetRequests"]]
    errors: list[str] = []

    priority_rank = {"urgent": 0, "high": 1, "normal": 2, "low": 3}
    generation_candidates = sorted(
        assets,
        key=lambda asset: (
            priority_rank.get(str(asset.get("priority")), 4),
            str(asset.get("id") or ""),
        ),
    )[:max_images]
    generate_ids = {asset["id"] for asset in generation_candidates}

    if request.generateImages and max_images > 0 and not (gemini_client or openai_client):
        errors.append(
            "No image provider is configured; set GEMINI_API_KEY or OPENAI_API_KEY."
        )

    for asset in assets:
        asset["createdAt"] = utc_now()
        asset["outputPath"] = None
        if not request.generateImages or asset["id"] not in generate_ids or not (
            gemini_client or openai_client
        ):
            asset["status"] = "prompt_ready"
            continue

        filename = slugify_filename(f"{asset['id']}-{asset['kind']}", asset["id"])
        output_path = output_dir / f"{filename}.png"
        full_prompt = (
            f"{asset['prompt']}\n\nNegative prompt: {asset['negativePrompt']}\n"
            "Output should be polished concept art / realistic key visual suitable "
            "for a fictional AI live host asset library."
        )
        try:
            result = generate_visual_image_asset(
                prompt=full_prompt,
                output_path=output_path,
                provider_preference=request.imageProvider,
                gemini_model=request.imageModel or GEMINI_IMAGE_MODEL,
                openai_model=request.openaiImageModel or OPENAI_IMAGE_MODEL,
                aspect_ratio=asset.get("aspectRatio") or request.aspectRatio,
                image_size=request.imageSize,
            )
            asset.update(
                {
                    "status": "generated",
                    "outputPath": result["path"],
                    "mimeType": result["mimeType"],
                    "bytes": result["bytes"],
                    "modelText": result.get("modelText", ""),
                    "imageProvider": result.get("provider"),
                    "imageModel": result.get("model"),
                    "fallbackErrors": result.get("fallbackErrors", []),
                }
            )
        except Exception as exc:
            message = str(exc)
            logger.warning("[VISUAL IMAGE GENERATION ERROR] %s", message, exc_info=True)
            asset.update({"status": "error", "error": message})
            errors.append(f"{asset['id']}: {message}")

    manifest = {
        "runId": run_id,
        "createdAt": utc_now(),
        "mode": request.mode,
        "provider": provider,
        "imageProvider": request.imageProvider,
        "imageModel": request.imageModel or GEMINI_IMAGE_MODEL,
        "openaiImageModel": request.openaiImageModel or OPENAI_IMAGE_MODEL,
        "objective": request.objective,
        "requestedBy": request.requestedBy,
        "slackRoute": target_channel,
        "outputDir": str(output_dir),
        "plan": plan,
        "assets": assets,
        "errors": errors[:12],
        "safetyBoundary": (
            "Inspiracao de lives reais deve ser apenas estetica anonima; o workflow "
            "nao deve copiar identidade ou likeness de pessoas reais."
        ),
    }
    (output_dir / "manifest.json").write_text(
        json.dumps(manifest, ensure_ascii=False, indent=2),
        encoding="utf-8",
    )

    runs = read_json_list(VISUAL_ASSET_RUNS_FILE)
    run_summary = {
        "runId": run_id,
        "createdAt": manifest["createdAt"],
        "provider": provider,
        "imageModel": manifest["imageModel"],
        "outputDir": str(output_dir),
        "assets": [
            {
                "id": asset.get("id"),
                "kind": asset.get("kind"),
                "title": asset.get("title"),
                "status": asset.get("status"),
                "outputPath": asset.get("outputPath"),
            }
            for asset in assets
        ],
        "errors": errors[:8],
    }
    runs.append(run_summary)
    write_json_list(VISUAL_ASSET_RUNS_FILE, runs[-MAX_VISUAL_ASSET_RUNS:])

    slack_message = build_visual_asset_slack_message(manifest)
    append_n8n_audit(
        "visual_asset_run",
        {
            "request": {
                "objective": request.objective,
                "mode": request.mode,
                "maxPrompts": max_prompts,
                "maxImages": max_images,
                "targetChannel": target_channel,
            },
            "run": run_summary,
        },
        {
            "ok": not errors,
            "provider": provider,
            "generated": len([asset for asset in assets if asset.get("status") == "generated"]),
            "errors": len(errors),
        },
    )

    return {
        "ok": True,
        "visualRun": manifest,
        "slackMessage": slack_message,
    }


@app.post("/project/continuous-organizer")
def run_continuous_project_organizer(request: ContinuousOrganizerRequest):
    focus_areas = normalize_focus_areas(request.focusAreas)
    max_tasks = max(1, min(request.maxTasks, 12))
    target_channel = normalize_slack_route(request.targetChannel, focus_areas[0])
    current_tasks = read_json_list(PROJECT_TASKS_FILE)
    recent_audit = read_json_list(N8N_AUDIT_FILE)[-20:]
    constraints = request.constraints or [
        "local-first",
        "sem edicao automatica de codigo",
        "organizar tarefas ate o produto final",
    ]
    contract = {
        "summary": "resumo curto da rodada",
        "currentPhase": "fase atual do produto",
        "recommendedFocus": focus_areas,
        "tasks": [
            {
                "id": "ODS-TASK-001",
                "title": "tarefa concreta para Lucas executar",
                "area": "produto | runtime | frontend | backend | automacao | qa | docs",
                "priority": "low | normal | high | urgent",
                "status": "next | todo | in_progress | blocked | done",
                "why": "por que esta tarefa importa para o produto final",
                "acceptanceCriteria": ["criterio objetivo"],
                "dependsOn": [],
            }
        ],
        "blocked": ["bloqueio que precisa de decisao humana"],
        "risks": ["risco atual"],
        "questions": ["pergunta curta para Lucas, se necessaria"],
        "nextActions": ["acao objetiva para a proxima rodada"],
    }
    user_payload = {
        "objective": request.objective,
        "cadence": request.cadence,
        "focusAreas": focus_areas,
        "maxTasks": max_tasks,
        "requestedBy": request.requestedBy,
        "constraints": constraints,
        "targetChannel": target_channel,
        "currentTasks": current_tasks[:40],
        "recentAudit": recent_audit,
        "productDefinition": (
            "Odessa e um runtime local-first onde uma Persona IA recebe eventos "
            "da live, decide acoes, executa ferramentas reais/simuladas e registra "
            "todo o ciclo em auditoria."
        ),
    }
    system_prompt = (
        "Voce e o organizador continuo do projeto Odessa. Seu trabalho e manter "
        "uma fila viva de tarefas pequenas, priorizadas e verificaveis ate o "
        "produto final. Nao execute codigo, nao prometa deploy e nao dependa de "
        "integracoes inexistentes. Produza JSON estrito."
    )
    user_prompt = (
        "Organize o proximo lote de tarefas do Odessa com este contexto:\n"
        f"{json.dumps(user_payload, ensure_ascii=False)}\n\n"
        "Retorne APENAS um objeto JSON valido seguindo este contrato:\n"
        f"{json.dumps(contract, ensure_ascii=False)}\n\n"
        "Regras:\n"
        "- Escreva em portugues do Brasil.\n"
        "- Priorize o caminho ate o produto final, nao tarefas cosmeticas soltas.\n"
        "- Marque exatamente 1 ou 2 tarefas como status next.\n"
        "- Preserve tarefas relevantes ja existentes quando ainda fizerem sentido.\n"
        "- Cada tarefa precisa ter criterio de aceite testavel.\n"
        "- Se faltar decisao humana, registre em questions ou blocked."
    )

    provider = "local-fallback"
    try:
        text, provider = generate_ai_text_with_fallback(
            gemini_model=request.model,
            system_prompt=system_prompt,
            user_prompt=user_prompt,
            temperature=request.temperature,
            json_mode=True,
        )
        parsed = extract_json_object(text or "{}")
    except Exception as exc:
        logger.warning("[CONTINUOUS ORGANIZER FALLBACK] %s", exc, exc_info=True)
        parsed = fallback_continuous_organizer(
            request,
            focus_areas,
            current_tasks,
            error=str(exc),
        )

    organizer = normalize_continuous_organizer(parsed, request, focus_areas)
    merged_tasks = merge_project_tasks(current_tasks, organizer["tasks"])
    write_json_list(PROJECT_TASKS_FILE, merged_tasks)

    runs = read_json_list(PROJECT_ORGANIZER_RUNS_FILE)
    artifact = {
        "organizerRunId": organizer["id"],
        "createdAt": organizer["createdAt"],
        "mode": "continuous_project_organizer",
        "provider": provider,
        "organizer": organizer,
        "tasks": merged_tasks[: max_tasks],
    }
    runs.append(artifact)
    write_json_list(PROJECT_ORGANIZER_RUNS_FILE, runs[-MAX_PROJECT_ORGANIZER_RUNS:])

    slack_message = build_organizer_slack_message(organizer)
    append_n8n_audit(
        "continuous_organizer_run",
        {
            "request": {
                "objective": request.objective,
                "cadence": request.cadence,
                "focusAreas": focus_areas,
                "targetChannel": target_channel,
            },
            "organizer": organizer,
        },
        {"ok": True, "provider": provider, "tasks": len(merged_tasks)},
    )
    return {
        "ok": True,
        "organizer": organizer,
        "tasks": merged_tasks[:max_tasks],
        "slackMessage": slack_message,
        "artifact": artifact,
    }


@app.post("/project/create-plan")
def create_project_plan(request: ProjectCreatePlanRequest):
    title = request.title.strip() or "Nova etapa Odessa"
    brief = request.brief.strip()
    if not brief:
        raise HTTPException(status_code=400, detail="brief is required")

    area = normalize_project_area(request.area)
    priority = normalize_project_priority(request.priority)
    target_channel = normalize_slack_route(request.targetChannel, area)
    constraints = request.constraints or []
    plan_contract = {
        "title": "nome curto e claro da etapa",
        "summary": "resumo executivo em portugues",
        "goals": ["objetivo concreto"],
        "milestones": [
            {
                "id": "ODS-M1",
                "title": "marco",
                "outcome": "resultado esperado",
            }
        ],
        "tasks": [
            {
                "id": "ODS-TASK-1",
                "title": "tarefa executavel",
                "area": area,
                "priority": priority,
                "status": "planned",
                "acceptanceCriteria": ["criterio objetivo"],
            }
        ],
        "decisions": ["decisao de produto ou tecnica"],
        "risks": ["risco ou dependencia"],
        "acceptanceCriteria": ["criterio de aceite geral"],
        "slackRoute": target_channel,
        "nextActions": ["proxima acao concreta"],
    }
    system_prompt = (
        "Voce e o planejador operacional do Odessa, um runtime local-first para "
        "Persona IA operando lives com captura, decisoes, acoes e auditoria. "
        "Transforme briefs em planos curtos, executaveis e rastreaveis. "
        "Nao prometa automacao real de codigo, GitHub ou integracoes externas quando "
        "o pedido for apenas organizacao de projeto. Responda somente JSON valido."
    )
    brief_payload = {
        "title": title,
        "brief": brief,
        "priority": priority,
        "area": area,
        "requestedBy": request.requestedBy,
        "constraints": constraints,
        "targetChannel": target_channel,
    }
    user_prompt = (
        "Brief recebido para criacao/evolucao do projeto Odessa:\n"
        f"{json.dumps(brief_payload, ensure_ascii=False)}\n\n"
        "Retorne APENAS um objeto JSON valido seguindo exatamente este contrato:\n"
        f"{json.dumps(plan_contract, ensure_ascii=False)}\n\n"
        "Regras:\n"
        "- Escreva em portugues do Brasil.\n"
        "- Crie tarefas pequenas, testaveis e ordenadas.\n"
        "- Inclua riscos reais e criterios de aceite objetivos.\n"
        "- Mantenha foco em Slack + JSON como saidas do primeiro ciclo.\n"
        "- Use IDs legiveis com prefixo ODS."
    )

    try:
        text, provider = generate_ai_text_with_fallback(
            gemini_model=request.model,
            system_prompt=system_prompt,
            user_prompt=user_prompt,
            temperature=request.temperature,
            json_mode=True,
        )
        parsed = extract_json_object(text or "{}")
        project_plan = normalize_project_plan(parsed, request)
        append_n8n_audit(
            "project_plan_created",
            {
                "request": {
                    "title": title,
                    "area": area,
                    "priority": priority,
                    "requestedBy": request.requestedBy,
                    "targetChannel": target_channel,
                },
                "projectPlan": project_plan,
            },
            {"ok": True, "provider": provider},
        )
        return {"ok": True, "projectPlan": project_plan}
    except HTTPException:
        raise
    except json.JSONDecodeError as exc:
        logger.error("[PROJECT PLAN JSON EXCEPTION] %s", exc, exc_info=True)
        raise HTTPException(status_code=502, detail="AI returned invalid project plan JSON") from exc
    except Exception as exc:
        logger.error("[PROJECT PLAN EXCEPTION] %s", exc, exc_info=True)
        raise HTTPException(status_code=502, detail=str(exc)) from exc


@app.post("/project/night-shift")
def create_night_shift_plan(request: NightShiftRequest):
    objective = request.objective.strip()
    if not objective:
        raise HTTPException(status_code=400, detail="objective is required")

    focus_areas = normalize_focus_areas(request.focusAreas)
    duration = max(15, min(request.durationMinutes, 480))
    max_advancements = max(1, min(request.maxAdvancements, 8))
    target_channel = normalize_slack_route(request.targetChannel, focus_areas[0])
    constraints = request.constraints or []
    contract = {
        "title": "Odessa Night Shift",
        "summary": "resumo do trabalho seguro preparado",
        "safeMode": True,
        "focusAreas": focus_areas,
        "advancements": [
            {
                "id": "ODS-NS-1",
                "title": "avanco preparado",
                "area": "runtime | automacao | qa | docs | produto | frontend | backend",
                "why": "por que isso importa",
                "tasks": ["tarefa pequena e executavel"],
                "acceptanceCriteria": ["criterio objetivo"],
                "risk": "risco ou dependencia",
                "handoffPrompt": "instrucao curta para retomar a execucao",
            }
        ],
        "decisions": ["decisao tomada para manter seguranca"],
        "risks": ["risco geral da rodada"],
        "morningBrief": "briefing curto para Lucas ao voltar",
        "slackRoute": target_channel,
    }
    system_prompt = (
        "Voce e o coordenador de uma rodada segura chamada Odessa Night Shift. "
        "Seu papel e preparar avancos de projeto enquanto Lucas descansa, mas sem "
        "executar alteracoes de codigo, comandos destrutivos, credenciais, deploys "
        "ou integracoes reais sem supervisao. Produza backlog, criterios, riscos e "
        "um briefing claro de retorno. Responda somente JSON valido."
    )
    user_payload = {
        "objective": objective,
        "durationMinutes": duration,
        "focusAreas": focus_areas,
        "maxAdvancements": max_advancements,
        "requestedBy": request.requestedBy,
        "constraints": constraints,
        "targetChannel": target_channel,
        "context": {
            "product": "Odessa",
            "currentMvp": "React/Vite + FastAPI local + Capture Studio + Persona Studio + Controle Live + n8n bridge",
            "safeBoundary": "Preparar e auditar avancos; nao alterar codigo automaticamente durante o cochilo.",
        },
    }
    user_prompt = (
        "Prepare uma rodada Night Shift para o Odessa com este payload:\n"
        f"{json.dumps(user_payload, ensure_ascii=False)}\n\n"
        "Retorne APENAS um objeto JSON valido seguindo este contrato:\n"
        f"{json.dumps(contract, ensure_ascii=False)}\n\n"
        "Regras:\n"
        "- Escreva em portugues do Brasil.\n"
        f"- Gere no maximo {max_advancements} avancos.\n"
        "- Cada avanco deve ter tarefas pequenas, criterios de aceite e um handoffPrompt.\n"
        "- Priorize automacao n8n, QA, documentacao operacional e clareza do runtime.\n"
        "- Nao inclua passos que exijam segredo, deploy, push, comandos destrutivos ou edicao automatica de codigo."
    )

    try:
        text, provider = generate_ai_text_with_fallback(
            gemini_model=request.model,
            system_prompt=system_prompt,
            user_prompt=user_prompt,
            temperature=request.temperature,
            json_mode=True,
        )
        parsed = extract_json_object(text or "{}")
        night_shift = normalize_night_shift_plan(parsed, request)
        append_n8n_audit(
            "night_shift_created",
            {
                "request": {
                    "objective": objective,
                    "durationMinutes": duration,
                    "focusAreas": focus_areas,
                    "requestedBy": request.requestedBy,
                    "targetChannel": target_channel,
                },
                "nightShift": night_shift,
            },
            {"ok": True, "provider": provider},
        )
        return {"ok": True, "nightShift": night_shift}
    except HTTPException:
        raise
    except json.JSONDecodeError as exc:
        logger.error("[NIGHT SHIFT JSON EXCEPTION] %s", exc, exc_info=True)
        raise HTTPException(status_code=502, detail="AI returned invalid night shift JSON") from exc
    except Exception as exc:
        logger.error("[NIGHT SHIFT EXCEPTION] %s", exc, exc_info=True)
        raise HTTPException(status_code=502, detail=str(exc)) from exc


@app.post("/ocr")
def perform_ocr(request: RegionRequest):
    started_at = time.perf_counter()
    zone_id = (request.zone_id or "global").strip() or "global"
    zone_name = (request.zone_name or zone_id).strip() or zone_id

    try:
        img_array = image_from_request(request)
        results = reader.readtext(img_array)
        text = " ".join(result[1] for result in results).strip()
        confidence_values = [
            float(result[2])
            for result in results
            if len(result) > 2 and isinstance(result[2], (float, int))
        ]
        confidence = (
            sum(confidence_values) / len(confidence_values)
            if confidence_values
            else None
        )

        previous_text = last_full_text_by_zone.get(zone_id, "")
        new_content = get_new_text(previous_text, text)
        last_full_text_by_zone[zone_id] = text

        if new_content and len(new_content) > 1:
            save_to_log(new_content)

        return {
            "text": new_content,
            "full_text": text,
            "error": None,
            "zone_id": zone_id,
            "zone_name": zone_name,
            "confidence": confidence,
            "latency_ms": round((time.perf_counter() - started_at) * 1000),
            "created_at": datetime.now(timezone.utc).isoformat(),
        }
    except HTTPException:
        raise
    except Exception as exc:
        logger.error("[OCR EXCEPTION] %s", exc, exc_info=True)
        return {
            "text": "",
            "full_text": "",
            "error": str(exc),
            "zone_id": zone_id,
            "zone_name": zone_name,
            "confidence": None,
            "latency_ms": round((time.perf_counter() - started_at) * 1000),
            "created_at": datetime.now(timezone.utc).isoformat(),
        }


@app.post("/ai/respond")
def generate_ai_response(request: AIRespondRequest):
    chat_context = request.chat_context.strip()
    if not chat_context:
        raise HTTPException(status_code=400, detail="chat_context is required")

    try:
        text, provider = generate_ai_text_with_fallback(
            gemini_model=request.model,
            system_prompt=request.persona_prompt,
            user_prompt=(
                "[MENSAGENS DO CHAT RECEBIDAS AGORA]:\n"
                f"{chat_context}\n\n"
                "Responda agora como a streamer:"
            ),
            temperature=request.temperature,
        )
        return {"response": text, "provider": provider}
    except HTTPException:
        raise
    except Exception as exc:
        logger.error("[AI EXCEPTION] %s", exc, exc_info=True)
        raise HTTPException(status_code=502, detail=str(exc)) from exc


@app.post("/ai/decide")
def generate_autopilot_decision(request: AIDecideRequest):
    if not request.events:
        raise HTTPException(status_code=400, detail="events is required")

    events_payload = [
        {
            "id": event.id,
            "source": event.source,
            "zoneName": event.zoneName,
            "kind": event.kind,
            "text": event.text,
            "createdAt": event.createdAt,
            "metadata": event.metadata or {},
        }
        for event in request.events[-5:]
    ]
    tools_payload = request.tools or []
    rules_payload = request.rules or []
    context_payload = request.context or {}
    fallback_text = events_payload[-1]["text"]

    decision_contract = {
        "context_analysis": "analise breve do que esta acontecendo no chat/live agora e qual o humor da streamer (PASSO 1: PENSAR)",
        "sentiment": "positivo | negativo | neutro | hype | caotico",
        "intent": "respond_chat | thank_gift | redeem_gift | moderate | switch_scene | media_request | topic_shift | handle_alert | log_only",
        "reason": "por que esta decisao foi escolhida",
        "priority": "low | normal | high | urgent",
        "actions": [
            {
                "id": "action-1",
                "type": "speak | chat_reply | ack_gift | moderate_message | switch_scene | show_overlay | play_music | play_video | stop_media | set_topic | suggest_topic | remember | log_event",
                "capability": "tts.speak | chat.reply | gift.acknowledge | moderation.message | obs.switch_scene | obs.show_overlay | media.play_music | media.play_video | media.stop | topic.set | topic.suggest | memory.remember | log.event",
                "label": "nome humano curto",
                "payload": {"text": "detalhes da acao"},
                "requiresApproval": False,
                "simulated": True,
                "status": "queued",
            }
        ],
        "speech": "O roteiro final e perfeito do que a streamer vai falar em voz alta (PASSO FINAL: FALAR)",
    }
    user_prompt = (
        "Eventos recentes da live em JSON:\n"
        f"{json.dumps(events_payload, ensure_ascii=False)}\n\n"
        "Ferramentas disponiveis em JSON:\n"
        f"{json.dumps(tools_payload, ensure_ascii=False)}\n\n"
        "Regras automaticas ja casadas em JSON:\n"
        f"{json.dumps(rules_payload, ensure_ascii=False)}\n\n"
        "Contexto operacional em JSON:\n"
        f"{json.dumps(context_payload, ensure_ascii=False)}\n\n"
        "Retorne APENAS um objeto JSON valido seguindo exatamente este contrato e na exata ordem das chaves (primeiro pense, depois gere a fala):\n"
        f"{json.dumps(decision_contract, ensure_ascii=False)}\n\n"
        "Regras:\n"
        "- Gere SEMPRE as chaves na ordem do contrato: primeiro context_analysis, depois sentiment, intent, reason, actions e POR ULTIMO speech.\n"
        "- O campo 'speech' deve ser gerado baseado na analise de contexto que voce acabou de escrever.\n"
        "- Inclua sempre uma action 'speak' com simulated=false para a fala da streamer.\n"
        "- Se uma regra automatica ja cobrir uma acao previsivel, nao duplique essa acao; complemente com fala/contexto.\n"
        "- Use metadata para diferenciar presente simples, resgate, cena, musica e topico.\n"
        "- Use 'ack_gift' para presentes, 'moderate_message' para spam/risco, "
        "'switch_scene' para pedido de cena/OBS, 'show_overlay' para alerta visual e "
        "'chat_reply' para resposta textual ao chat. Use 'play_music' ou 'play_video' "
        "para pedidos de midia e 'suggest_topic' para chat quieto.\n"
        "- Acoes externas que nao sejam speak devem vir com simulated=true.\n"
        "- Seja seguro, curto e operacional."
    )

    try:
        text, provider = generate_ai_text_with_fallback(
            gemini_model=request.model,
            system_prompt=request.persona_prompt,
            user_prompt=user_prompt,
            temperature=request.temperature,
            json_mode=True,
        )
        try:
            parsed = extract_json_object(text or "{}")
        except json.JSONDecodeError:
            if provider != "gemini" or not openai_client:
                raise
            logger.warning("[GEMINI JSON FALLBACK] Retrying decision with OpenAI")
            text = generate_openai_text(
                request.persona_prompt,
                user_prompt,
                request.temperature,
                json_mode=True,
            )
            provider = "openai"
            parsed = extract_json_object(text or "{}")

        decision = normalize_decision(parsed, fallback_text)
        decision["provider"] = provider
        return decision
    except HTTPException:
        raise
    except json.JSONDecodeError as exc:
        logger.error("[AI DECIDE JSON EXCEPTION] %s", exc, exc_info=True)
        raise HTTPException(status_code=502, detail="AI returned invalid JSON") from exc
    except Exception as exc:
        logger.error("[AI DECIDE EXCEPTION] %s", exc, exc_info=True)
        raise HTTPException(status_code=502, detail=str(exc)) from exc


@app.get("/regions")
