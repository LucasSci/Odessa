        },
    }


@app.get("/log")
def get_log():
    try:
        if LOG_FILE.exists():
            lines = LOG_FILE.read_text(encoding="utf-8").splitlines(keepends=True)
            return {"log": lines[-50:], "total_lines": len(lines)}
        return {"log": [], "total_lines": 0}
    except Exception as exc:
        raise HTTPException(status_code=500, detail=str(exc)) from exc


@app.post("/clear-log")
def clear_log():
    try:
        LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
        LOG_FILE.write_text("", encoding="utf-8")
        return {"message": "Log cleared"}
    except Exception as exc:
        raise HTTPException(status_code=500, detail=str(exc)) from exc


@app.post("/tts")
async def generate_tts(request: Request):
    try:
        data = await request.json()
    except Exception as exc:
        raise HTTPException(status_code=400, detail="Invalid JSON body") from exc
    text = data.get("text", "").strip()
    provider = infer_tts_provider(data.get("provider"), str(data.get("voice") or ""))
    voice = default_voice_for_provider(provider, str(data.get("voice") or ""))
    try:
        speed = float(data.get("speed", KOKORO_DEFAULT_SPEED))
    except (TypeError, ValueError):
        speed = KOKORO_DEFAULT_SPEED
    speed = max(0.65, min(1.35, speed))
    try:
        pitch = float(data.get("pitch", 0))
    except (TypeError, ValueError):
        pitch = 0.0
    pitch = max(-12.0, min(12.0, pitch))

    if not text:
        raise HTTPException(status_code=400, detail="No text provided")

    temp_path: Optional[str] = None
    try:
        if provider == "openai":
            if not openai_client:
                raise HTTPException(
                    status_code=503,
                    detail="OPENAI_API_KEY is not configured for premium TTS voices",
                )
            if voice not in OPENAI_TTS_VOICES:
                voice = "nova"
        elif provider == "kokoro":
            if not kokoro_available():
                raise HTTPException(
                    status_code=503,
                    detail="Kokoro TTS is not ready. Install kokoro, soundfile and espeak-ng.",
                )
            if voice not in KOKORO_VOICES:
                voice = KOKORO_DEFAULT_VOICE
            voice_meta = KOKORO_VOICES.get(voice, {})
            if voice_meta.get("disabled_reason") or voice_meta.get("lang") in KOKORO_DISABLED_LANGS:
                raise HTTPException(
                    status_code=400,
                    detail=f"Kokoro voice {voice} is listed but unavailable: {voice_meta.get('disabled_reason', 'language runtime not installed')}",
                )

        suffix = ".wav" if provider == "kokoro" else ".mp3"
        media_type = "audio/wav" if provider == "kokoro" else "audio/mpeg"
        temp_file = tempfile.NamedTemporaryFile(delete=False, suffix=suffix)
        temp_path = temp_file.name
        temp_file.close()

        if provider == "openai":
            response = openai_client.audio.speech.create(
                model=OPENAI_TTS_MODEL,
                voice=voice,
                input=text,
                speed=speed,
            )
            response.stream_to_file(temp_path)
        elif provider == "kokoro":
            generate_kokoro_wav(text, voice, speed, temp_path)
        else:
            communicate = edge_tts.Communicate(
                text,
                voice,
                rate=edge_rate_from_speed(speed),
                pitch=edge_pitch_from_value(pitch),
            )
            await communicate.save(temp_path)

        return FileResponse(
            temp_path,
            media_type=media_type,
            headers={
                "X-Odessa-TTS-Provider": provider,
                "X-Odessa-TTS-Voice": voice,
                "X-Odessa-TTS-Sample-Rate": "24000" if provider == "kokoro" else "",
                "X-Odessa-TTS-Speed": str(speed),
                "X-Odessa-TTS-Pitch": str(pitch),
            },
            background=BackgroundTask(cleanup_temp_file, temp_path),
        )
    except HTTPException:
        if temp_path:
            cleanup_temp_file(temp_path)
        raise
    except Exception as exc:
        if temp_path:
            cleanup_temp_file(temp_path)
        logger.error("[TTS EXCEPTION] %s", exc, exc_info=True)
        raise HTTPException(status_code=502, detail=str(exc)) from exc


@app.get("/tts/voices")
def get_tts_voices():
    kokoro_package = package_installed("kokoro")
    espeak_path = espeak_ng_path()
    kokoro_ready = kokoro_available()
    edge_voices = load_edge_voices()
    return {
        "defaultProvider": TTS_DEFAULT_PROVIDER,
        "providers": {
            "edge": {"configured": True, "enabled": True, "supports": {"speed": True, "pitch": True}},
            "openai": {
                "configured": bool(OPENAI_API_KEY),
                "enabled": bool(openai_client),
                "defaultModel": OPENAI_TTS_MODEL,
                "supports": {"speed": True, "pitch": False},
            },
            "kokoro": {
                "configured": kokoro_ready,
                "enabled": KOKORO_ENABLED,
                "packageInstalled": kokoro_package,
                "espeakInstalled": bool(espeak_path),
                "espeakPath": espeak_path,
                "defaultLang": KOKORO_DEFAULT_LANG,
                "defaultVoice": KOKORO_DEFAULT_VOICE,
                "defaultSpeed": KOKORO_DEFAULT_SPEED,
                "supports": {"speed": True, "pitch": False},
            },
        },
        "voices": [
            *[
                {
                    "provider": "edge",
                    "id": str(voice.get("ShortName") or ""),
                    "label": edge_voice_label(voice),
                    "language": str(voice.get("Locale") or ""),
                    "gender": str(voice.get("Gender") or "unknown").lower(),
                    "enabled": True,
                    "configured": True,
                    "reason": None,
                }
                for voice in edge_voices
                if voice.get("ShortName")
            ],
            *[
                {
                    "provider": "openai",
                    "id": voice_id,
                    "label": voice_id.title(),
                    "language": "multi",
                    "gender": "neutral",
                    "enabled": bool(openai_client),
                    "configured": bool(openai_client),
                    "reason": None if openai_client else "OPENAI_API_KEY ausente",
                }
                for voice_id in sorted(OPENAI_TTS_VOICES)
            ],
            *[
                {
                    "provider": "kokoro",
                    "id": voice_id,
                    "label": str(meta["label"]),
                    "language": str(meta["lang"]),
                    "gender": str(meta["gender"]),
                    "grade": str(meta.get("grade") or ""),
                    "experimental": str(meta.get("grade") or "").lower() == "experimental",
                    "enabled": kokoro_ready
                    and not meta.get("disabled_reason")
                    and meta.get("lang") not in KOKORO_DISABLED_LANGS,
                    "configured": kokoro_ready,
                    "reason": meta.get("disabled_reason")
                    or (None if kokoro_ready else "Kokoro, soundfile ou espeak-ng indisponivel"),
                }
                for voice_id, meta in KOKORO_VOICES.items()
            ],
        ],
    }


